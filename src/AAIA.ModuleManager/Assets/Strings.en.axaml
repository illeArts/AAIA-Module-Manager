<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

  <!-- ── Navigation ── -->
  <sys:String x:Key="Str_Tab_Sdk">🔧  SDK / Contracts</sys:String>
  <sys:String x:Key="Str_Tab_Module">📦  My Module</sys:String>
  <sys:String x:Key="Str_Tab_Registry">🌐  Registry</sys:String>
  <sys:String x:Key="Str_Tab_Tester">🧪  Tester</sys:String>
  <sys:String x:Key="Str_Tab_Setup">⚙️  Setup</sys:String>
  <sys:String x:Key="Str_Menu_Settings">Settings</sys:String>
  <sys:String x:Key="Str_Menu_Help">Help</sys:String>
  <sys:String x:Key="Str_Menu_About">About</sys:String>

  <!-- ── General ── -->
  <sys:String x:Key="Str_Save">Save</sys:String>
  <sys:String x:Key="Str_Cancel">Cancel</sys:String>
  <sys:String x:Key="Str_Close">Close</sys:String>
  <sys:String x:Key="Str_Refresh">↻ Refresh</sys:String>
  <sys:String x:Key="Str_Browse">Browse</sys:String>
  <sys:String x:Key="Str_Connect">Connect</sys:String>
  <sys:String x:Key="Str_Disconnect">Disconnect</sys:String>
  <sys:String x:Key="Str_Build">🔨  Build &amp; Publish</sys:String>
  <sys:String x:Key="Str_Install">⬆  Install + Enable</sys:String>
  <sys:String x:Key="Str_HotReload">🔄  Hot-Reload</sys:String>
  <sys:String x:Key="Str_Simulate">▶  Simulate</sys:String>
  <sys:String x:Key="Str_Stream_Start">▶ Stream</sys:String>
  <sys:String x:Key="Str_Stream_Stop">◼ Stop</sys:String>
  <sys:String x:Key="Str_Clear">🗑</sys:String>
  <sys:String x:Key="Str_PopOut">⤢</sys:String>
  <sys:String x:Key="Str_Copy">📋  Copy</sys:String>

  <!-- ── Settings ── -->
  <sys:String x:Key="Str_Settings_Title">Settings</sys:String>
  <sys:String x:Key="Str_Settings_Language">Language / Sprache</sys:String>
  <sys:String x:Key="Str_Settings_De">🇩🇪  Deutsch</sys:String>
  <sys:String x:Key="Str_Settings_En">🇬🇧  English</sys:String>

  <!-- ── Help ── -->
  <sys:String x:Key="Str_Help_Title">Help — AAIA Module Manager v2</sys:String>
  <sys:String x:Key="Str_Help_Subtitle">The complete dev assistant for AAIA module and plugin developers.</sys:String>

</ResourceDictionary>
