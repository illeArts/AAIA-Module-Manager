<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AAIA.ModuleManager.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme />
    <StyleInclude Source="avares://AAIA.ModuleManager/Styles/AppTheme.axaml" />
  </Application.Styles>

  <!-- Default language: DE. LanguageService.SetLanguage() swaps this at runtime. -->
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://AAIA.ModuleManager/Assets/Strings.de.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

</Application>
