<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AAIA.ModuleManager.ViewModels"
        xmlns:tabs="using:AAIA.ModuleManager.Views.Tabs"
        xmlns:views="using:AAIA.ModuleManager.Views"
        x:Class="AAIA.ModuleManager.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="AAIA Module Manager v2"
        Width="1200" Height="720"
        MinWidth="760" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="#1a1a2e">

  <Grid RowDefinitions="38,*">

    <!-- ── Titelzeile ── -->
    <Grid Grid.Row="0"
          Background="#12122a"
          IsHitTestVisible="True"
          PointerPressed="TitleBar_PointerPressed">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <!-- Logo + Titel -->
      <StackPanel Grid.Column="0" Orientation="Horizontal"
                  VerticalAlignment="Center" Margin="12,0,0,0" Spacing="8">
        <Image Source="avares://AAIA.ModuleManager/Assets/AAIA_Module_Manager.png"
               Width="22" Height="22" RenderOptions.BitmapInterpolationMode="HighQuality"/>
        <TextBlock Text="AAIA Module Manager  v2"
                   Foreground="#e0e0e0" FontWeight="SemiBold" FontSize="13"
                   VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Menüleiste -->
      <StackPanel Grid.Column="1" Orientation="Horizontal"
                  VerticalAlignment="Center" Margin="16,0,0,0" Spacing="4">
        <Button Classes="menu-btn" Content="{DynamicResource Str_Menu_Settings}" Click="Settings_Click"/>
        <Button Classes="menu-btn" Content="{DynamicResource Str_Menu_Help}" Click="Help_Click"/>
        <Button Classes="menu-btn" Content="{DynamicResource Str_Menu_About}" Click="About_Click"/>
      </StackPanel>

      <!-- ETW-Identität — rechts vor Fenster-Buttons -->
      <StackPanel Grid.Column="2" Orientation="Horizontal"
                  VerticalAlignment="Center" Margin="0,0,10,0" Spacing="7"
                  IsVisible="{Binding IsLoggedIn}">
        <Rectangle Width="1" Height="14" Fill="#2a2a4a" VerticalAlignment="Center"/>
        <Ellipse Width="7" Height="7" Fill="#5865f2" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding DeveloperDisplayName}"
                   Foreground="#c8cde4" FontSize="12" FontWeight="SemiBold"
                   VerticalAlignment="Center"/>
        <TextBlock Text="·" Foreground="#3a3a5a" FontSize="12" VerticalAlignment="Center"/>
        <TextBlock Text="{Binding DeveloperEtwId}"
                   Foreground="#5865f2" FontSize="11"
                   VerticalAlignment="Center"/>
        <Rectangle Width="1" Height="14" Fill="#2a2a4a" VerticalAlignment="Center"/>
        <Button Content="Abmelden" Classes="logout-btn"
                Click="Logout_Click" VerticalAlignment="Center"/>
      </StackPanel>

      <!-- Fenster-Buttons -->
      <StackPanel Grid.Column="3" Orientation="Horizontal"
                  VerticalAlignment="Center" Margin="0,0,8,0" Spacing="4">
        <Button Classes="wnd-btn" Content="─" Click="Minimize_Click"/>
        <Button Classes="wnd-btn" Content="□" Click="Maximize_Click"/>
        <Button Classes="wnd-btn close-btn" Content="✕" Click="Close_Click"/>
      </StackPanel>
    </Grid>

    <!-- ── Hauptinhalt ── -->
    <TabControl Grid.Row="1" Margin="0">

      <!-- ── ETW + Owner Tabs (immer zuerst → Tab 0 ist immer sichtbar) ── -->

      <!-- Tab 1: Mein Modul / Plugin -->
      <TabItem Header="{DynamicResource Str_Tab_Module}"
               IsVisible="{Binding IsEtw}">
        <tabs:ModuleTab DataContext="{Binding ModuleTab}"/>
      </TabItem>

      <!-- Tab 2: Extension Registry -->
      <TabItem Header="{DynamicResource Str_Tab_Registry}"
               IsVisible="{Binding IsEtw}">
        <tabs:RegistryTab DataContext="{Binding RegistryTab}"/>
      </TabItem>

      <!-- Tab 3: Tester (V2) -->
      <TabItem Header="{DynamicResource Str_Tab_Tester}"
               IsVisible="{Binding IsEtw}">
        <views:TesterTab DataContext="{Binding TesterTab}"/>
      </TabItem>

      <!-- Tab 4: Setup -->
      <TabItem Header="{DynamicResource Str_Tab_Setup}"
               IsVisible="{Binding IsEtw}">
        <tabs:SetupTab DataContext="{Binding SetupTab}"/>
      </TabItem>

      <!-- Tab 5: Developer Account / Marketplace -->
      <TabItem Header="Developer"
               IsVisible="{Binding IsEtw}">
        <tabs:DeveloperTab DataContext="{Binding DeveloperTab}"/>
      </TabItem>

      <!-- Tab 6: Publish — Build, Sign, Marketplace-Upload -->
      <TabItem Header="Publish"
               IsVisible="{Binding IsEtw}">
        <tabs:PublishTab DataContext="{Binding PublishTab}"/>
      </TabItem>

      <!-- Tab 7: Meine Lizenzen — für alle sichtbar (auch ohne ETW-Login) -->
      <TabItem Header="🔑  Lizenzen">
        <tabs:LicensesTab DataContext="{Binding LicensesTab}"/>
      </TabItem>

      <!-- Tab 8: Marketplace Browse — für alle sichtbar -->
      <TabItem Header="🛒  Marketplace">
        <tabs:MarketplaceBrowseTab DataContext="{Binding BrowseTab}"/>
      </TabItem>

      <!-- ── Owner-only Tabs (am Ende — werden bei ETW nie ausgewählt) ── -->

      <!-- Tab 8: SDK / Contracts (nur Owner) -->
      <TabItem Header="{DynamicResource Str_Tab_Sdk}"
               IsVisible="{Binding IsOwner}">
        <tabs:SdkTab DataContext="{Binding SdkTab}"/>
      </TabItem>

    </TabControl>

  </Grid>

  <Window.Styles>
    <Style Selector="Button.menu-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#8892a4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="10,4"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.menu-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1a2040"/>
      <Setter Property="TextElement.Foreground" Value="#e0e0e0"/>
    </Style>
    <Style Selector="Button.wnd-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#8892a4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="26"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.wnd-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#2a2a4a"/>
    </Style>
    <Style Selector="Button.close-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#c0392b"/>
      <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.logout-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#8892a4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="6,2"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.logout-btn:pointerover /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="#e74c3c"/>
    </Style>
  </Window.Styles>

</Window>
