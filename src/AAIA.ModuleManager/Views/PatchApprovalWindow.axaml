<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AAIA.ModuleManager.ViewModels"
        x:Class="AAIA.ModuleManager.Views.PatchApprovalWindow"
        x:DataType="vm:PatchApprovalViewModel"
        Title="🔍  Patch-Vorschlag prüfen — AAIA Module Manager"
        Width="1100" Height="760"
        MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117"
        Foreground="#e0e0e0"
        FontFamily="Inter,Segoe UI,sans-serif">

  <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto">

    <!-- ── Header ── -->
    <Border Grid.Row="0" Background="#1a0a0a" Padding="28,16,28,14">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Spacing="3">
          <TextBlock Text="🔍  Patch-Vorschlag prüfen"
                     FontSize="18" FontWeight="Bold" Foreground="#f87171"/>
          <TextBlock Text="Ein externer KI-Connector hat Änderungen vorgeschlagen. Prüfe jeden Patch sorgfältig."
                     FontSize="12" Foreground="#8892a4"/>
        </StackPanel>
        <TextBlock Grid.Column="2"
                   Text="{Binding Counter}"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="#f59e0b"
                   VerticalAlignment="Center"/>
      </Grid>
    </Border>

    <!-- ── Patch-Info ── -->
    <Border Grid.Row="1" Background="#111827" Padding="20,10"
            BorderBrush="#2a1a1a" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="*,24,*,24,*">

        <!-- Zieldatei -->
        <StackPanel Grid.Column="0" Spacing="3">
          <TextBlock Text="ZIELDATEI" FontSize="9" Foreground="#4a5a6a" FontWeight="SemiBold" LetterSpacing="1.5"/>
          <TextBlock Text="{Binding TargetFile}"
                     FontSize="12" FontFamily="Cascadia Code,Consolas,monospace"
                     Foreground="#60a5fa"
                     TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Art -->
        <StackPanel Grid.Column="2" Spacing="3">
          <TextBlock Text="ART" FontSize="9" Foreground="#4a5a6a" FontWeight="SemiBold" LetterSpacing="1.5"/>
          <TextBlock Text="{Binding PatchKind}"
                     FontSize="12" Foreground="#a78bfa"/>
        </StackPanel>

        <!-- Beschreibung -->
        <StackPanel Grid.Column="4" Spacing="3">
          <TextBlock Text="BESCHREIBUNG" FontSize="9" Foreground="#4a5a6a" FontWeight="SemiBold" LetterSpacing="1.5"/>
          <TextBlock Text="{Binding Description, FallbackValue='(keine Beschreibung)'}"
                     FontSize="12" Foreground="#8892a4"
                     TextTrimming="CharacterEllipsis"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Rationale (wenn vorhanden) -->
    <Border Grid.Row="2" Background="#0f1a0f" Padding="20,8"
            BorderBrush="#1a3a1a" BorderThickness="0,0,0,1"
            IsVisible="{Binding Rationale, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
      <StackPanel Spacing="2">
        <TextBlock Text="BEGRÜNDUNG DER KI" FontSize="9" Foreground="#4a6a4a" FontWeight="SemiBold" LetterSpacing="1.5"/>
        <TextBlock Text="{Binding Rationale}"
                   FontSize="11" Foreground="#6fcf97"
                   TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <!-- ── Diff-Ansicht: Vorher | Nachher ── -->
    <Grid Grid.Row="3" ColumnDefinitions="*,1,*">

      <!-- Vorher (aktueller Dateiinhalt) -->
      <Grid Grid.Column="0" RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#1a1208" Padding="16,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="VORHER" FontSize="9" FontWeight="SemiBold"
                       Foreground="#f59e0b" LetterSpacing="1.5" VerticalAlignment="Center"/>
            <TextBlock Text="(aktuelle Datei)"
                       FontSize="10" Foreground="#4a5a6a" VerticalAlignment="Center"/>
            <Border Background="#2a1a08" CornerRadius="3" Padding="6,2"
                    IsVisible="{Binding !FileExists}">
              <TextBlock Text="Datei existiert noch nicht" FontSize="10" Foreground="#f59e0b"/>
            </Border>
          </StackPanel>
        </Border>
        <TextBox Grid.Row="1"
                 Text="{Binding BeforeContent}"
                 Background="#0c0f0a"
                 Foreground="#d4c898"
                 FontFamily="Cascadia Code,Consolas,monospace"
                 FontSize="11"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 Padding="16,12"
                 Watermark="(Datei existiert noch nicht)"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
      </Grid>

      <!-- Trennlinie -->
      <Rectangle Grid.Column="1" Fill="#2a2a3a"/>

      <!-- Nachher (Vorschlag der KI) -->
      <Grid Grid.Column="2" RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#081a0a" Padding="16,8">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="NACHHER" FontSize="9" FontWeight="SemiBold"
                       Foreground="#6fcf97" LetterSpacing="1.5" VerticalAlignment="Center"/>
            <TextBlock Text="(Vorschlag der KI)"
                       FontSize="10" Foreground="#4a5a6a" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
        <TextBox Grid.Row="1"
                 Text="{Binding AfterContent}"
                 Background="#080c08"
                 Foreground="#b8f0c8"
                 FontFamily="Cascadia Code,Consolas,monospace"
                 FontSize="11"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 Padding="16,12"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
      </Grid>
    </Grid>

    <!-- ── Status ── -->
    <Border Grid.Row="4"
            Background="#1a1a0a"
            Padding="20,6"
            IsVisible="{Binding HasStatus}">
      <TextBlock Text="{Binding StatusText}"
                 FontSize="11"
                 Foreground="#f59e0b"/>
    </Border>

    <!-- ── Entscheidungs-Footer ── -->
    <Border Grid.Row="5" Background="#12122a" Padding="16,10">
      <Grid ColumnDefinitions="Auto,8,Auto,*,Auto,8,Auto,8,Auto,8,Auto">

        <!-- Navigation -->
        <Button Grid.Column="0"
                Content="◀  Zurück"
                Classes="ghost"
                FontSize="12"
                Command="{Binding PreviousCommand}"
                IsEnabled="{Binding HasPrevious}"/>

        <Button Grid.Column="2"
                Content="Weiter  ▶"
                Classes="ghost"
                FontSize="12"
                Command="{Binding NextCommand}"
                IsEnabled="{Binding HasNext}"/>

        <!-- Spacer -->

        <!-- Sicherheitshinweis -->
        <TextBlock Grid.Column="4"
                   Text="🔒  Nur freigegebene Dateien werden verändert."
                   FontSize="10" Foreground="#3a4a5a"
                   VerticalAlignment="Center"/>

        <!-- Alle ablehnen -->
        <Button Grid.Column="6"
                Content="✗  Alle ablehnen"
                Classes="ghost"
                FontSize="12"
                Foreground="#f87171"
                IsEnabled="{Binding !IsCompleted}"
                Command="{Binding RejectAllCommand}"/>

        <!-- Ablehnen -->
        <Button Grid.Column="8"
                Content="✗  Ablehnen"
                Classes="ghost"
                FontSize="12"
                Foreground="#f87171"
                IsEnabled="{Binding !IsCompleted}"
                Command="{Binding RejectCommand}"/>

        <!-- Übernehmen -->
        <Button Grid.Column="10"
                Content="✓  Übernehmen"
                Classes="primary"
                FontSize="12"
                IsEnabled="{Binding !IsCompleted}"
                Command="{Binding ApproveCommand}"/>

      </Grid>
    </Border>

  </Grid>
</Window>
