<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AAIA.ModuleManager.Views.HelpWindow"
        Title="{DynamicResource Str_Help_Title}"
        Width="760" Height="600"
        MinWidth="540" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="#0d1117"
        Foreground="#e0e0e0"
        FontFamily="Inter,Segoe UI,sans-serif">

  <Grid RowDefinitions="Auto,*,Auto" Margin="0">

    <!-- Header -->
    <Border Grid.Row="0" Background="#12122a" Padding="28,20,28,16">
      <StackPanel Spacing="4">
        <TextBlock Text="{DynamicResource Str_Help_Title}"
                   FontSize="18" FontWeight="Bold" Foreground="#e0e0e0"/>
        <TextBlock Text="{DynamicResource Str_Help_Subtitle}"
                   FontSize="12" Foreground="#8892a4"/>
      </StackPanel>
    </Border>

    <!-- Scrollable content -->
    <ScrollViewer Grid.Row="1" Padding="28,16,28,0">
      <StackPanel Spacing="0" x:Name="HelpContent" Margin="0,0,0,24"/>
    </ScrollViewer>

    <!-- Footer -->
    <Border Grid.Row="2" Background="#12122a" Padding="16,10">
      <Button Classes="primary"
              Content="{DynamicResource Str_Close}"
              HorizontalAlignment="Right"
              Click="Close_Click"/>
    </Border>

  </Grid>

</Window>
