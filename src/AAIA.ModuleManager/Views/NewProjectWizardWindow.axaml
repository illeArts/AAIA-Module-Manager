<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AAIA.ModuleManager.ViewModels"
        xmlns:services="using:AAIA.ModuleManager.Services"
        x:Class="AAIA.ModuleManager.Views.NewProjectWizardWindow"
        x:DataType="vm:NewProjectWizardViewModel"
        Title="🪄  Neues AAIA-Projekt"
        Width="640" Height="620"
        MinWidth="540" MinHeight="500"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a2e"
        Foreground="#e0e0e0"
        FontFamily="Inter,Segoe UI,sans-serif">

  <!-- Vier Steps als überlappende Grids — nur je eines sichtbar -->
  <Grid>

    <!-- ═══════════════════════════════ STEP 0: Idee eingeben ══════════════ -->
    <Grid x:Name="Step0Panel" RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="28,24,28,0" Spacing="4">
        <TextBlock Text="Was möchtest du mit AAIA erweitern?"
                   FontSize="18" FontWeight="Bold"/>
        <TextBlock Text="Beschreibe deine Idee — der Module Manager hilft dir, den richtigen Typ zu finden."
                   FontSize="12" Foreground="#8892a4" TextWrapping="Wrap"/>
      </StackPanel>

      <!-- Inhalt: Grid statt StackPanel — Textfeld füllt verfügbaren Raum -->
      <Grid Grid.Row="1" RowDefinitions="*,Auto,Auto" Margin="28,16,28,8">

        <!-- Idee-Textfeld — nimmt gesamten verfügbaren Platz -->
        <TextBox Grid.Row="0"
                 x:Name="IdeaBox"
                 Text="{Binding IdeaText, Mode=TwoWay}"
                 Watermark="z. B.: Ich moechte ein Modul bauen, das meine FRITZ!Box ueberwacht."
                 AcceptsReturn="True"
                 MinHeight="120"
                 TextWrapping="Wrap"
                 Background="#12122a"
                 Foreground="#e0e0e0"
                 BorderBrush="#2a2a4a"
                 BorderThickness="1"
                 CornerRadius="8"
                 Padding="12,10"
                 FontSize="13"
                 VerticalAlignment="Stretch"/>

        <!-- Kein API-Key → Info — am unteren Rand -->
        <Border Grid.Row="1"
                IsVisible="{Binding HasNoApiKey}"
                Background="#1a1a0a"
                BorderBrush="#3a3a1a"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,8"
                Margin="0,10,0,0">
          <StackPanel Spacing="3">
            <TextBlock Text="⚠  Kein KI-Assistent konfiguriert"
                       FontSize="12" FontWeight="SemiBold" Foreground="#c8a040"/>
            <TextBlock Text="Die KI-Analyse ist nicht verfügbar. Du kannst deine Idee trotzdem eingeben — sie wird als Beschreibung übernommen."
                       FontSize="11" Foreground="#8892a4" TextWrapping="Wrap"/>
            <TextBlock Text="Einstellungen → KI-Assistent → Anbieter &amp; API-Schlüssel"
                       FontSize="11" Foreground="#5865f2"/>
          </StackPanel>
        </Border>

        <!-- Analyse läuft -->
        <StackPanel Grid.Row="2"
                    IsVisible="{Binding IsAnalyzing}"
                    Orientation="Horizontal" Spacing="8"
                    Margin="0,6,0,0">
          <TextBlock Text="⏳" FontSize="13" VerticalAlignment="Center"/>
          <TextBlock Text="{Binding AnalyzeStatus}"
                     FontSize="12" Foreground="#5865f2"
                     FontStyle="Italic" VerticalAlignment="Center"/>
        </StackPanel>

      </Grid>

      <!-- Button-Leiste -->
      <Border Grid.Row="2"
              BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
              Padding="28,10,28,20">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="{Binding PublisherId, StringFormat='Publisher: {0}'}"
                     Foreground="#3a3f5a" FontSize="11"
                     VerticalAlignment="Center"/>

          <!-- Ohne KI weiter (immer sichtbar, aber sekundär wenn API-Key vorhanden) -->
          <Button Grid.Column="1"
                  Content="Direkt manuell eingeben →"
                  Classes="ghost"
                  Margin="0,0,8,0"
                  Command="{Binding SkipToManualCommand}"
                  IsEnabled="{Binding !IsAnalyzing}"/>

          <!-- Mit KI analysieren (nur wenn API-Key vorhanden) -->
          <Button Grid.Column="2"
                  IsVisible="{Binding HasApiKey}"
                  Classes="primary"
                  Command="{Binding AnalyzeIdeaCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="✨" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock Text="Idee analysieren" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Weiter (kein API-Key) -->
          <Button Grid.Column="2"
                  IsVisible="{Binding HasNoApiKey}"
                  Classes="primary"
                  Command="{Binding SkipToManualCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="Weiter →" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

        </Grid>
      </Border>
    </Grid>


    <!-- ═══════════════════════════════ STEP 1: Analyse-Ergebnis ═══════════ -->
    <Grid x:Name="Step1Panel" IsVisible="False" RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="28,24,28,0" Spacing="4">
        <TextBlock Text="KI-Vorschlag" FontSize="18" FontWeight="Bold"/>
        <TextBlock Text="Schau dir den Vorschlag an. Du kannst ihn übernehmen oder manuell einen anderen Typ wählen."
                   FontSize="12" Foreground="#8892a4" TextWrapping="Wrap"/>
      </StackPanel>

      <!-- Inhalt -->
      <ScrollViewer Grid.Row="1" Padding="28,16,28,8">
        <StackPanel Spacing="12">

          <!-- Offline-Fallback -->
          <Border IsVisible="{Binding AnalysisOffline}"
                  Background="#1a1a2e"
                  BorderBrush="#2a2a4a"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="16,14">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
              <TextBlock Text="🔌" FontSize="28" HorizontalAlignment="Center"/>
              <TextBlock Text="KI-Analyse nicht verfügbar"
                         FontSize="14" FontWeight="SemiBold"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="Bitte wähle den Erweiterungstyp manuell."
                         FontSize="12" Foreground="#8892a4"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Gültiger Vorschlag -->
          <Border IsVisible="{Binding !AnalysisOffline}"
                  Background="#151530"
                  BorderBrush="#3a3a6a"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="18,16">
            <StackPanel Spacing="10">

              <!-- Empfohlener Typ -->
              <StackPanel Spacing="4">
                <TextBlock Text="Das klingt nach:"
                           FontSize="11" Foreground="#8892a4" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding AnalysisResult.DisplayTypeName}"
                           FontSize="16" FontWeight="Bold" Foreground="#e0e0ff"/>
                <TextBlock Text="{Binding AnalysisResult.TargetRuntime, StringFormat='Zielsystem: {0}'}"
                           FontSize="11" Foreground="#5865f2"/>
              </StackPanel>

              <Rectangle Height="1" Fill="#2a2a4a"/>

              <!-- Begründung -->
              <StackPanel Spacing="4">
                <TextBlock Text="Warum?" FontSize="11" Foreground="#8892a4" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding AnalysisResult.Reason}"
                           FontSize="12" Foreground="#c8cde4"
                           TextWrapping="Wrap" LineHeight="18"/>
              </StackPanel>

              <!-- Risiko -->
              <StackPanel Orientation="Horizontal" Spacing="6">
                <TextBlock Text="{Binding AnalysisResult.RiskEmoji}" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding AnalysisResult.RiskLabel}"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
              </StackPanel>

              <!-- Empfohlene Rechte (optional) -->
              <StackPanel Spacing="4"
                          IsVisible="{Binding AnalysisResult.HasSuggestedPermissions}">
                <TextBlock Text="Empfohlene Rechte:"
                           FontSize="11" Foreground="#8892a4" FontWeight="SemiBold"/>
                <ItemsControl ItemsSource="{Binding AnalysisResult.SuggestedPermissions}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding ., StringFormat='·  {0}'}"
                                 FontSize="12" Foreground="#7a8099"
                                 FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <!-- Nächste Schritte (optional) -->
              <StackPanel Spacing="4"
                          IsVisible="{Binding AnalysisResult.HasNextSteps}">
                <TextBlock Text="Empfohlene nächste Schritte:"
                           FontSize="11" Foreground="#8892a4" FontWeight="SemiBold"/>
                <ItemsControl ItemsSource="{Binding AnalysisResult.NextSteps}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding ., StringFormat='→  {0}'}"
                                 FontSize="12" Foreground="#7a8099"
                                 TextWrapping="Wrap"/>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

            </StackPanel>
          </Border>

          <!-- Hinweis: KI kann sich irren -->
          <TextBlock Text="Der Vorschlag ist eine Empfehlung. Du kannst im nächsten Schritt jederzeit einen anderen Typ wählen."
                     FontSize="11" Foreground="#4a5070"
                     TextWrapping="Wrap" HorizontalAlignment="Center"
                     IsVisible="{Binding !AnalysisOffline}"/>

        </StackPanel>
      </ScrollViewer>

      <!-- Button-Leiste -->
      <Border Grid.Row="2"
              BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
              Padding="28,10,28,20">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <Button Grid.Column="0"
                  Content="← Zurück" Classes="ghost"
                  Command="{Binding BackCommand}"/>
          <Button Grid.Column="2"
                  Content="Manuell auswählen"
                  Classes="ghost" Margin="0,0,8,0"
                  Command="{Binding GoToManualSelectionCommand}"/>
          <Button Grid.Column="3"
                  Classes="primary"
                  IsVisible="{Binding !AnalysisOffline}"
                  Command="{Binding UseAnalysisSuggestionCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="✓" FontSize="13" VerticalAlignment="Center"/>
              <TextBlock Text="Vorschlag übernehmen" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>


    <!-- ═══════════════════════════════ STEP 2: Projektdetails ═════════════ -->
    <Grid x:Name="Step2Panel" IsVisible="False" RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="28,24,28,0" Spacing="4">
        <TextBlock Text="Erweiterung konfigurieren"
                   FontSize="18" FontWeight="Bold"/>
        <TextBlock Text="Wähle den Typ und fülle die Details aus. Alle Dateien werden automatisch erzeugt."
                   FontSize="12" Foreground="#8892a4" TextWrapping="Wrap"/>
      </StackPanel>

      <!-- Inhalt -->
      <ScrollViewer Grid.Row="1" Padding="28,16,28,8">
        <StackPanel Spacing="16">

          <!-- Projekttyp -->
          <Border Background="#202042" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="14">
            <StackPanel Spacing="10">
              <TextBlock Text="Erweiterungstyp" FontSize="13" FontWeight="SemiBold"/>

              <RadioButton x:Name="RadioServerModule"
                           IsChecked="True"
                           GroupName="ProjectType"
                           Click="RadioServerModule_Click">
                <StackPanel Spacing="1">
                  <TextBlock Text="🖥  Server-Modul (AAIAS)" FontWeight="SemiBold" FontSize="13"/>
                  <TextBlock Text="Läuft auf dem AAIAS-Server · IAaiaModule · ASP.NET Core · Plattformunabhängig"
                             FontSize="11" Foreground="#8892a4"/>
                </StackPanel>
              </RadioButton>

              <RadioButton x:Name="RadioClientPlugin"
                           GroupName="ProjectType"
                           Click="RadioClientPlugin_Click">
                <StackPanel Spacing="1">
                  <TextBlock Text="📦  Client-Plugin (AAIAC)" FontWeight="SemiBold" FontSize="13"/>
                  <TextBlock Text="Erweitert den AAIAC-Client · IAaiacPlugin · UI/Logik"
                             FontSize="11" Foreground="#8892a4"/>
                </StackPanel>
              </RadioButton>

              <RadioButton x:Name="RadioHybridModule"
                           GroupName="ProjectType"
                           Click="RadioHybridModule_Click">
                <StackPanel Spacing="1">
                  <TextBlock Text="🔀  Hybrid-Modul (AAIAS + AAIAC)" FontWeight="SemiBold" FontSize="13"/>
                  <TextBlock Text="Erstellt Server/ + Client/ im selben Ordner · Braucht beide Laufzeiten"
                             FontSize="11" Foreground="#8892a4"/>
                </StackPanel>
              </RadioButton>

              <RadioButton x:Name="RadioLanguagePack"
                           GroupName="ProjectType"
                           Click="RadioLanguagePack_Click">
                <StackPanel Spacing="1">
                  <TextBlock Text="🌐  Sprachpaket" FontWeight="SemiBold" FontSize="13"/>
                  <TextBlock Text="JSON-Übersetzungen · Kein C# erforderlich · Für AAIAS und AAIAC"
                             FontSize="11" Foreground="#8892a4"/>
                </StackPanel>
              </RadioButton>

            </StackPanel>
          </Border>

          <!-- Details -->
          <Border Background="#202042" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="14">
            <StackPanel Spacing="14">
              <TextBlock Text="Projektdetails" FontSize="13" FontWeight="SemiBold"/>

              <!-- Name -->
              <StackPanel Spacing="5">
                <TextBlock Text="Projektname *" Foreground="#8892a4" FontSize="12"/>
                <TextBox x:Name="NameBox"
                         Text="{Binding ProjectName, Mode=TwoWay}"
                         Watermark="z. B. FritzBox Connector"
                         Background="#12122a" Foreground="#e0e0e0"
                         BorderBrush="#2a2a4a" BorderThickness="1"
                         CornerRadius="6" Padding="10,7" FontSize="13"/>
              </StackPanel>

              <!-- ID (auto) -->
              <StackPanel Spacing="5">
                <TextBlock Text="Erweiterungs-ID (automatisch)" Foreground="#8892a4" FontSize="12"/>
                <TextBox Text="{Binding ProjectId, Mode=TwoWay}"
                         Watermark="aaia.module.my-extension"
                         Background="#12122a" Foreground="#5865f2"
                         BorderBrush="#2a2a4a" BorderThickness="1"
                         CornerRadius="6" Padding="10,7" FontSize="12"
                         FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
              </StackPanel>

              <!-- Beschreibung -->
              <StackPanel Spacing="5">
                <TextBlock Text="Beschreibung" Foreground="#8892a4" FontSize="12"/>
                <TextBox Text="{Binding Description, Mode=TwoWay}"
                         Watermark="Kurze Beschreibung..."
                         AcceptsReturn="True" Height="60"
                         TextWrapping="Wrap"
                         Background="#12122a" Foreground="#e0e0e0"
                         BorderBrush="#2a2a4a" BorderThickness="1"
                         CornerRadius="6" Padding="10,7" FontSize="12"/>
              </StackPanel>

              <!-- Ausgabepfad -->
              <StackPanel Spacing="5">
                <TextBlock Text="Ausgabepfad *" Foreground="#8892a4" FontSize="12"/>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBox Grid.Column="0"
                           Text="{Binding OutputPath, Mode=TwoWay}"
                           Background="#12122a" Foreground="#e0e0e0"
                           BorderBrush="#2a2a4a" BorderThickness="1"
                           CornerRadius="6" Padding="10,7" FontSize="12"/>
                  <Button Grid.Column="1" Content="…" Margin="6,0,0,0"
                          Classes="ghost"
                          Command="{Binding PickOutputPathCommand}"/>
                </Grid>
                <TextBlock Text="Das Projekt wird als Unterordner hier erstellt."
                           FontSize="11" Foreground="#4a5070"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Fehler-Anzeige -->
          <Border x:Name="ErrorBorder"
                  IsVisible="False"
                  Background="#2e1a1a"
                  BorderBrush="#4a2a2a"
                  BorderThickness="1" CornerRadius="6" Padding="12,10">
            <TextBlock x:Name="ErrorText"
                       TextWrapping="Wrap" FontSize="12" Foreground="#e07070"/>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- Button-Leiste -->
      <Border Grid.Row="2"
              BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
              Padding="28,10,28,20">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Button Grid.Column="0"
                  Content="← Zurück" Classes="ghost"
                  Command="{Binding BackCommand}"/>
          <TextBlock Grid.Column="1"
                     Text="{Binding PublisherId, StringFormat='Publisher: {0}'}"
                     Foreground="#3a3f5a" FontSize="11"
                     HorizontalAlignment="Center" VerticalAlignment="Center"/>
          <Button Grid.Column="2"
                  Classes="primary"
                  x:Name="CreateBtn"
                  Command="{Binding CreateCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="✨" FontSize="13" VerticalAlignment="Center"/>
              <TextBlock x:Name="CreateBtnLabel" Text="Erstellen"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>


    <!-- ═══════════════════════════════ STEP 3: Erfolg ══════════════════════ -->
    <Grid x:Name="Step3Panel" IsVisible="False" RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <StackPanel Grid.Row="0" Margin="28,24,28,0" Spacing="4">
        <StackPanel Orientation="Horizontal" Spacing="10">
          <TextBlock Text="✓" FontSize="22" Foreground="#4ade80" VerticalAlignment="Center"/>
          <TextBlock Text="Projekt wurde erstellt!"
                     FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        </StackPanel>
        <TextBlock x:Name="CreatedPathLabel"
                   Text=""
                   FontSize="11"
                   Foreground="#5865f2"
                   FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                   TextWrapping="Wrap"/>
      </StackPanel>

      <!-- Inhalt -->
      <ScrollViewer Grid.Row="1" Padding="28,16,28,8">
        <StackPanel Spacing="14">

          <!-- ── Build-Karte (nur wenn Build moeglich) ── -->
          <Border Background="#202042" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="16,14"
                  IsVisible="{Binding IsBuildableType}">
            <StackPanel Spacing="10">

              <StackPanel Spacing="3">
                <TextBlock Text="Naechster sinnvoller Schritt"
                           FontSize="11" Foreground="#8892a4" FontWeight="SemiBold"/>
                <TextBlock Text="Baue das Projekt einmal, um zu pruefen ob dein System bereit ist."
                           FontSize="13" TextWrapping="Wrap"/>
              </StackPanel>

              <!-- Build-Buttons (nur wenn nicht am laufen) -->
              <StackPanel Orientation="Horizontal" Spacing="8"
                          IsVisible="{Binding !IsBuildRunning}">
                <Button Classes="primary"
                        Command="{Binding BuildProjectCommand}"
                        IsEnabled="{Binding !IsBuildRunning}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🔨" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="Jetzt bauen" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
                <Button Classes="ghost"
                        Command="{Binding OpenInExplorerCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="📂" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="Im Explorer oeffnen" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>

              <!-- Build laeuft -->
              <StackPanel IsVisible="{Binding IsBuildRunning}"
                          Orientation="Horizontal" Spacing="8">
                <TextBlock Text="⏳" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="Build laeuft..." FontSize="12"
                           Foreground="#5865f2" FontStyle="Italic"
                           VerticalAlignment="Center"/>
              </StackPanel>

              <!-- ── Build-Ergebnis: Erfolg ── -->
              <Border IsVisible="{Binding BuildSuccess}"
                      Background="#0a1a0a" BorderBrush="#1a4a1a"
                      BorderThickness="1" CornerRadius="6" Padding="12,8">
                <StackPanel Spacing="4">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="✓" FontSize="14" Foreground="#4ade80" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastBuildResult.SummaryLabel}"
                               FontSize="12" Foreground="#4ade80" VerticalAlignment="Center"/>
                  </StackPanel>
                </StackPanel>
              </Border>

              <!-- ── Build-Ergebnis: Fehler — uebersetzte Issues ── -->
              <StackPanel IsVisible="{Binding BuildFailed}" Spacing="8">

                <!-- Zusammenfassung -->
                <Border Background="#1a0a0a" BorderBrush="#4a1a1a"
                        BorderThickness="1" CornerRadius="6" Padding="12,8">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="✖" FontSize="14" Foreground="#e05252" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LastBuildResult.SummaryLabel}"
                               FontSize="12" Foreground="#e05252" VerticalAlignment="Center"/>
                  </StackPanel>
                </Border>

                <!-- Fehler-Karten -->
                <ItemsControl ItemsSource="{Binding BuildIssues}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:BuildIssueViewModel">
                      <Border Margin="0,0,0,6"
                              Background="#18100e"
                              BorderBrush="{Binding BorderBrushColor}"
                              BorderThickness="1" CornerRadius="6"
                              Padding="12,10">
                        <StackPanel Spacing="6">

                          <!-- Titel + Code -->
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding SeverityIcon}"
                                       FontSize="13" VerticalAlignment="Center"
                                       Foreground="{Binding SeverityForeground}"/>
                            <TextBlock Text="{Binding Title}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <Border Background="{Binding CodeBackground}" CornerRadius="3" Padding="5,1">
                              <TextBlock Text="{Binding Code}"
                                         FontSize="10"
                                         Foreground="{Binding CodeForeground}"
                                         FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                            </Border>
                          </StackPanel>

                          <!-- Menschliche Erklaerung -->
                          <TextBlock Text="{Binding HumanMessage}"
                                     FontSize="12" Foreground="#b0b8c4"
                                     TextWrapping="Wrap" LineHeight="18"/>

                          <!-- Datei + Zeile falls vorhanden -->
                          <TextBlock IsVisible="{Binding HasLocation}"
                                     FontSize="10" Foreground="#5865f2"
                                     Text="{Binding LocationLabel}"
                                     FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>

                          <!-- Aktions-Buttons + Hilfe -->
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <ItemsControl IsVisible="{Binding HasActions}"
                                          ItemsSource="{Binding SuggestedActions}">
                              <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                  <StackPanel Orientation="Horizontal" Spacing="6"/>
                                </ItemsPanelTemplate>
                              </ItemsControl.ItemsPanel>
                              <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:BuildActionViewModel">
                                  <Button Content="{Binding Label}"
                                          Classes="ghost"
                                          FontSize="11"
                                          Command="{Binding ExecuteCommand}"/>
                                </DataTemplate>
                              </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button IsVisible="{Binding HasHelp}"
                                    Content="❓ Hilfe"
                                    Classes="ghost"
                                    FontSize="11"
                                    Foreground="#5865f2"
                                    Command="{Binding OpenHelpCommand}"
                                    ToolTip.Tip="Hilfeartikel zu diesem Fehler öffnen"/>
                          </StackPanel>

                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>

              <!-- Details-Toggle + Roh-Output -->
              <Border IsVisible="{Binding BuildOutput, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      Background="#0d0d1a" BorderBrush="#1a1a3a"
                      BorderThickness="1" CornerRadius="6">
                <StackPanel>
                  <!-- Toggle-Button -->
                  <Button Classes="ghost"
                          Command="{Binding ToggleRawOutputCommand}"
                          Padding="10,6" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left">
                    <TextBlock Text="{Binding RawOutputToggleLabel}"
                               FontSize="11" Foreground="#5a607a"/>
                  </Button>
                  <!-- Roh-Output -->
                  <ScrollViewer IsVisible="{Binding ShowRawOutput}" MaxHeight="160">
                    <TextBox Text="{Binding BuildOutput}"
                             IsReadOnly="True"
                             Background="Transparent"
                             Foreground="#7a8090"
                             BorderThickness="0"
                             Padding="10,6"
                             FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                             FontSize="10"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>
                  </ScrollViewer>
                </StackPanel>
              </Border>

            </StackPanel>
          </Border>

          <!-- Explorer-Button fuer Sprachpakete (kein Build) -->
          <Border Background="#202042" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="16,14"
                  IsVisible="{Binding !IsBuildableType}">
            <StackPanel Spacing="10">
              <TextBlock Text="Naechster sinnvoller Schritt"
                         FontSize="11" Foreground="#8892a4" FontWeight="SemiBold"/>
              <TextBlock Text="Oeffne den Projektordner und fuelle die JSON-Uebersetzungsdateien aus."
                         FontSize="13" TextWrapping="Wrap"/>
              <Button Classes="primary"
                      Command="{Binding OpenInExplorerCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="📂" FontSize="12" VerticalAlignment="Center"/>
                  <TextBlock Text="Projektordner oeffnen" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>

          <!-- In IDE oeffnen -->
          <Border Background="#202042" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="16,14">
            <StackPanel Spacing="8">
              <TextBlock Text="In IDE oeffnen" FontSize="12" FontWeight="SemiBold"/>
              <StackPanel x:Name="Step3IdePanel" Orientation="Horizontal" Spacing="8">
                <!-- IDE-Buttons werden per Code-behind befuellt -->
                <TextBlock x:Name="NoIdeText"
                           Text="Keine kompatible IDE erkannt."
                           FontSize="11" Foreground="#4a5070"/>
              </StackPanel>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- Button-Leiste -->
      <Border Grid.Row="2"
              BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
              Padding="28,10,28,20">
        <Grid ColumnDefinitions="*,Auto,Auto">
          <TextBlock Grid.Column="0"
                     Text="Build abgeschlossen."
                     Foreground="#3a3f5a" FontSize="11"
                     VerticalAlignment="Center"/>
          <Button Grid.Column="1" Classes="ghost" Margin="0,0,8,0"
                  Content="Fertig" Click="Close_Click"/>
          <Button Grid.Column="2" Classes="primary"
                  IsEnabled="{Binding CanCheckPublishReadiness}"
                  Command="{Binding CheckPublishReadinessCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="📦" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock Text="Paketprüfung →" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>


    <!-- ═══════════════════════════════ STEP 4: Projektprüfung ═════════════ -->
    <Grid x:Name="Step4Panel" IsVisible="False" RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <Grid Grid.Row="0" Margin="28,24,28,0" ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock x:Name="ValidationHeaderIcon" Text="🔍"
                       FontSize="20" VerticalAlignment="Center"/>
            <TextBlock Text="Projektprüfung"
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="Prüft ob dein Projekt bereit für die Paketierung ist."
                     FontSize="12" Foreground="#8892a4" TextWrapping="Wrap"/>
        </StackPanel>
        <Button Grid.Column="1" Content="? Hilfe" Classes="ghost" FontSize="11"
                VerticalAlignment="Top" Click="Help_Click" Margin="8,0,0,0"/>
      </Grid>

      <!-- Inhalt -->
      <ScrollViewer Grid.Row="1" Padding="28,16,28,8">
        <StackPanel Spacing="12">

          <!-- Prüft gerade... -->
          <StackPanel IsVisible="{Binding IsValidating}"
                      HorizontalAlignment="Center" Spacing="8"
                      Margin="0,20,0,0">
            <TextBlock Text="⏳" FontSize="28" HorizontalAlignment="Center"/>
            <TextBlock Text="Projekt wird geprüft..."
                       FontSize="13" Foreground="#5865f2"
                       FontStyle="Italic" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Ergebnis-Header (wenn fertig) -->
          <Border IsVisible="{Binding ValidationResult, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Background="#151530" BorderBrush="#2a2a5a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="4">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Text="{Binding ValidationResult.OverallIcon}"
                           FontSize="18" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ValidationResult.OverallStatus}"
                           FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding ValidationResult.ErrorCount,   StringFormat='🔴 {0} Blocker'}"
                           FontSize="11" Foreground="#e05252"/>
                <TextBlock Text="{Binding ValidationResult.WarningCount, StringFormat='🟡 {0} Empfehlungen'}"
                           FontSize="11" Foreground="#c9a227"/>
                <TextBlock Text="{Binding ValidationResult.InfoCount,    StringFormat='🔵 {0} Hinweise'}"
                           FontSize="11" Foreground="#5865f2"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Issue-Karten -->
          <ItemsControl ItemsSource="{Binding ValidationIssues}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ValidationIssueViewModel">
                <Border Margin="0,0,0,6"
                        Background="#18100e"
                        BorderBrush="{Binding BorderBrushColor}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12,10">
                  <StackPanel Spacing="6">

                    <!-- Titel + Kategorie-Badge -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding SeverityIcon}"
                                 FontSize="13" VerticalAlignment="Center"
                                 Foreground="{Binding SeverityForeground}"/>
                      <TextBlock Text="{Binding Title}"
                                 FontSize="13" FontWeight="SemiBold"
                                 VerticalAlignment="Center"/>
                      <Border Background="{Binding BadgeBackground}" CornerRadius="3" Padding="5,1">
                        <TextBlock Text="{Binding CategoryLabel}"
                                   FontSize="10"
                                   Foreground="{Binding SeverityForeground}"
                                   FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                      </Border>
                    </StackPanel>

                    <!-- Nachricht -->
                    <TextBlock Text="{Binding Message}"
                               FontSize="12" Foreground="#b0b8c4"
                               TextWrapping="Wrap" LineHeight="18"/>

                    <!-- Aktions-Buttons + Hilfe -->
                    <StackPanel Orientation="Horizontal" Spacing="6">
                      <ItemsControl IsVisible="{Binding HasActions}"
                                    ItemsSource="{Binding Actions}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6"/>
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate x:DataType="vm:ValidationActionViewModel">
                            <Button Content="{Binding Label}"
                                    Classes="ghost"
                                    FontSize="11"
                                    Command="{Binding ExecuteCommand}"/>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                      <Button IsVisible="{Binding HasHelp}"
                              Content="❓ Hilfe"
                              Classes="ghost"
                              FontSize="11"
                              Foreground="#5865f2"
                              Command="{Binding OpenHelpCommand}"
                              ToolTip.Tip="Hilfeartikel zu diesem Problem öffnen"/>
                    </StackPanel>

                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

        </StackPanel>
      </ScrollViewer>

      <!-- Button-Leiste -->
      <Border Grid.Row="2"
              BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
              Padding="28,10,28,20">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
          <Button Grid.Column="0"
                  Content="← Zurück" Classes="ghost"
                  Click="ValidationBack_Click"/>
          <Button Grid.Column="2"
                  Content="Erneut prüfen" Classes="ghost"
                  Margin="0,0,8,0"
                  Command="{Binding ValidateProjectCommand}"/>
          <Button Grid.Column="3" Classes="ghost"
                  Content="Fertig" Margin="0,0,8,0"
                  Click="Close_Click"/>
          <Button Grid.Column="4" Classes="primary"
                  IsEnabled="{Binding CanBuild}"
                  Command="{Binding ProceedToBuildCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="🔨" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock Text="Weiter: Bauen →" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>


    <!-- ═══════════════════════════════ STEP 5: Paketprüfung ════════════════ -->
    <Grid x:Name="Step5Panel" IsVisible="False" RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <Grid Grid.Row="0" Margin="28,24,28,0" ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="{Binding PublishStatusIcon}" FontSize="20" VerticalAlignment="Center"/>
            <TextBlock Text="Paketprüfung"
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="{Binding PublishStatusLabel}"
                     FontSize="12" Foreground="#8892a4"/>
          <!-- Dateiname des erzeugten Pakets -->
          <TextBlock IsVisible="{Binding IsPackaged}"
                     Text="{Binding LastPackageResult.PackageName, StringFormat='📦 {0}'}"
                     FontSize="11" Foreground="#5865f2"
                     FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
        </StackPanel>
        <Button Grid.Column="1" Content="? Hilfe" Classes="ghost" FontSize="11"
                VerticalAlignment="Top" Click="Help_Click" Margin="8,0,0,0"/>
      </Grid>

      <!-- Inhalt -->
      <ScrollViewer Grid.Row="1" Padding="28,16,28,8">
        <StackPanel Spacing="12">

          <!-- Lädt: Readiness-Prüfung -->
          <StackPanel IsVisible="{Binding IsCheckingReadiness}"
                      HorizontalAlignment="Center" Spacing="8" Margin="0,20,0,0">
            <TextBlock Text="⏳" FontSize="28" HorizontalAlignment="Center"/>
            <TextBlock Text="Prüfung läuft..."
                       FontSize="13" Foreground="#5865f2"
                       FontStyle="Italic" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Publish-Readiness Issue-Karten -->
          <ItemsControl ItemsSource="{Binding PublishIssues}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ValidationIssueViewModel">
                <Border Margin="0,0,0,6"
                        Background="#18100e"
                        BorderBrush="{Binding BorderBrushColor}"
                        BorderThickness="1" CornerRadius="6"
                        Padding="12,10">
                  <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <TextBlock Text="{Binding SeverityIcon}"
                                 FontSize="13" VerticalAlignment="Center"
                                 Foreground="{Binding SeverityForeground}"/>
                      <TextBlock Text="{Binding Title}"
                                 FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                      <Border Background="{Binding BadgeBackground}" CornerRadius="3" Padding="5,1">
                        <TextBlock Text="{Binding CategoryLabel}"
                                   FontSize="10" Foreground="{Binding SeverityForeground}"
                                   FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                      </Border>
                    </StackPanel>
                    <TextBlock Text="{Binding Message}"
                               FontSize="12" Foreground="#b0b8c4"
                               TextWrapping="Wrap" LineHeight="18"/>
                    <ItemsControl IsVisible="{Binding HasActions}" ItemsSource="{Binding Actions}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" Spacing="6"/>
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ValidationActionViewModel">
                          <Button Content="{Binding Label}" Classes="ghost"
                                  FontSize="11" Command="{Binding ExecuteCommand}"/>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- ─── Inspection-Blocker-Banner ──────────────────────────────────── -->
          <Border IsVisible="{Binding HasInspectionBlockers}"
                  Background="#1a0808" BorderBrush="#5a1a1a"
                  BorderThickness="2" CornerRadius="8" Padding="14,12">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <TextBlock Text="⛔" FontSize="20" VerticalAlignment="Center"/>
              <StackPanel Spacing="3">
                <TextBlock Text="Dieses Paket darf nicht veröffentlicht werden."
                           FontSize="13" FontWeight="Bold" Foreground="#e05252"/>
                <TextBlock FontSize="11" Foreground="#b0b8c4" TextWrapping="Wrap">
                  Das Paket enthält verbotene Dateien oder Sicherheitsprobleme.
                  Löse alle Blocker und erstelle das Paket neu.
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Versions-Karte -->
          <Border Background="#202042" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="8">
              <TextBlock Text="Version" FontSize="12" FontWeight="SemiBold"/>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="ghost" FontSize="11"
                        Command="{Binding IncreasePatchVersionCommand}">
                  Patch +0.0.1
                </Button>
                <Button Classes="ghost" FontSize="11"
                        Command="{Binding IncreaseMinorVersionCommand}">
                  Minor +0.1.0
                </Button>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- ─── Paket-Dateiliste (nach Inspektion) ─────────────────────────── -->
          <Border IsVisible="{Binding IsInspected}"
                  Background="#111118" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="0">
            <StackPanel>
              <!-- Dateilisten-Header -->
              <Border Padding="14,10" BorderBrush="#2a2a4a" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="📋" FontSize="13" VerticalAlignment="Center"/>
                    <TextBlock Text="Paketinhalt" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding InspectionResult.FileCount, StringFormat='{}{0} Dateien'}"
                               FontSize="11" Foreground="#8892a4" VerticalAlignment="Center"/>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="{Binding InspectionResult.BlockerCount, StringFormat='⛔ {0}'}"
                               FontSize="11" Foreground="#e05252" VerticalAlignment="Center"
                               IsVisible="{Binding HasInspectionBlockers}"/>
                    <TextBlock Text="{Binding InspectionResult.WarningCount, StringFormat='⚠ {0}'}"
                               FontSize="11" Foreground="#c9a227" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding InspectionResult.PackageSizeLabel}"
                               FontSize="11" Foreground="#8892a4" VerticalAlignment="Center"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Datei-Einträge -->
              <ItemsControl ItemsSource="{Binding PackageFileEntries}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="vm:PackageFileEntryViewModel">
                    <Border Padding="14,7" BorderBrush="#1e1e2e" BorderThickness="0,0,0,1">
                      <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding RiskIcon}"
                                   FontSize="11" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding CategoryIcon}"
                                   FontSize="11" VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Path}"
                                   FontSize="11"
                                   Foreground="{Binding PathColor}"
                                   FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Grid.Column="3"
                                   Text="{Binding SizeLabel}"
                                   FontSize="10" Foreground="#4a5070"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Paket-Info (Hash + Pfad) -->
          <Border IsVisible="{Binding LastPackageResult, Converter={x:Static ObjectConverters.IsNotNull}}"
                  Background="#0a1a0a" BorderBrush="#1a4a1a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="6">
              <TextBlock Text="📦 Paket erstellt" FontSize="13" FontWeight="SemiBold" Foreground="#4ade80"/>
              <TextBlock Text="{Binding LastPackageResult.PackagePath}"
                         FontSize="11" Foreground="#5865f2"
                         FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                         TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="{Binding LastPackageResult.SizeLabel, StringFormat='Größe: {0}'}"
                           FontSize="11" Foreground="#8892a4"/>
                <TextBlock Text="{Binding LastPackageResult.PackageHash, StringFormat='SHA256: {0}'}"
                           FontSize="10" Foreground="#4a5070"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Registry-Vorschau -->
          <Border IsVisible="{Binding ShowRegistryPreview}"
                  Background="#151530" BorderBrush="#2a2a6a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="8">
              <TextBlock Text="🔍 Marketplace-Vorschau" FontSize="13" FontWeight="SemiBold"/>
              <TextBlock Text="So würde dein Modul im AAIA Marketplace erscheinen:"
                         FontSize="11" Foreground="#8892a4"/>
              <ScrollViewer MaxHeight="200">
                <TextBox Text="{Binding RegistryPreviewJson}"
                         IsReadOnly="True"
                         Background="Transparent"
                         Foreground="#7ab3f5"
                         BorderThickness="0"
                         Padding="0"
                         FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                         FontSize="11"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"/>
              </ScrollViewer>
            </StackPanel>
          </Border>

          <!-- ─── Phase-4-Hinweis: Signierung ──────────────────────────────── -->
          <Border Background="#1a1400" BorderBrush="#3a2a00"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="🔏" FontSize="16" VerticalAlignment="Center"/>
              <StackPanel Spacing="2">
                <TextBlock Text="Noch nicht signiert" FontSize="12" FontWeight="SemiBold"
                           Foreground="#c9a227"/>
                <TextBlock FontSize="11" Foreground="#8892a4" TextWrapping="Wrap">
                  Signierung folgt in Phase 4. Pakete können jetzt erstellt und lokal getestet werden —
                  für den Marketplace-Upload wird später eine Signatur benötigt.
                </TextBlock>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- ─── Release-Status ────────────────────────────────────────────── -->
          <!-- Wird vorbereitet... -->
          <StackPanel IsVisible="{Binding IsPreparingRelease}"
                      HorizontalAlignment="Center" Spacing="8" Margin="0,4,0,0">
            <TextBlock Text="📁" FontSize="24" HorizontalAlignment="Center"/>
            <TextBlock Text="Release-Ordner wird vorbereitet..."
                       FontSize="13" Foreground="#5865f2"
                       FontStyle="Italic" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Release bereit -->
          <Border IsVisible="{Binding IsReleasePrepared}"
                  Background="#0a1a0a" BorderBrush="#1a4a1a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="✅" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="Release vorbereitet" FontSize="13" FontWeight="SemiBold"
                           Foreground="#4ade80" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="{Binding ReleaseFolderPath}"
                         FontSize="11" Foreground="#5865f2"
                         FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                         TextWrapping="Wrap"/>
              <StackPanel Orientation="Horizontal" Spacing="16">
                <TextBlock Text="Signatur: Noch nicht signiert"
                           FontSize="11" Foreground="#c9a227"/>
                <TextBlock Text="Marketplace: Noch nicht bereit"
                           FontSize="11" Foreground="#8892a4"/>
              </StackPanel>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- Button-Leiste -->
      <Border Grid.Row="2"
              BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
              Padding="28,10,28,20">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">
          <Button Grid.Column="0"
                  Content="← Zurück" Classes="ghost"
                  Click="PublishBack_Click"/>
          <Button Grid.Column="2"
                  Content="Erneut prüfen" Classes="ghost"
                  Margin="0,0,8,0"
                  Command="{Binding CheckPublishReadinessCommand}"/>
          <Button Grid.Column="3"
                  Content="📂 Paketordner" Classes="ghost"
                  Margin="0,0,8,0"
                  IsEnabled="{Binding IsPackaged}"
                  Command="{Binding OpenPackageFolderCommand}"/>
          <Button Grid.Column="4"
                  Content="📁 Release-Ordner" Classes="ghost"
                  Margin="0,0,8,0"
                  IsEnabled="{Binding CanOpenReleaseFolder}"
                  Command="{Binding OpenReleaseFolderCommand}"/>
          <Button Grid.Column="5" Classes="ghost"
                  Margin="0,0,8,0"
                  IsEnabled="{Binding CanPackage}"
                  Command="{Binding CreatePackageCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="📦" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock Text="Paket erstellen" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="6" Classes="ghost"
                  IsEnabled="{Binding CanPrepareRelease}"
                  Margin="0,0,8,0"
                  Command="{Binding PrepareReleaseCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="🚀" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock Text="Release vorbereiten" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="7" Classes="primary"
                  IsEnabled="{Binding CanProceedToSignature}"
                  Command="{Binding NavigateToSignatureCommand}">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock Text="🔏" FontSize="12" VerticalAlignment="Center"/>
              <TextBlock Text="Signatur &amp; Vertrauen →" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>


    <!-- ═══════════════════════════════ STEP 6: Signatur & Vertrauen ══════════ -->
    <Grid x:Name="Step6Panel" IsVisible="False" RowDefinitions="Auto,*,Auto">

      <!-- Header -->
      <Grid Grid.Row="0" Margin="28,24,28,0" ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock Text="🔏" FontSize="20" VerticalAlignment="Center"/>
            <TextBlock Text="Signatur &amp; Vertrauen"
                       FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
          </StackPanel>
          <TextBlock Text="{Binding SignatureStatusLabel}"
                     FontSize="12" Foreground="#8892a4"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6"
                    VerticalAlignment="Top" Margin="8,0,0,0">
          <Button Content="? Hilfe" Classes="ghost" FontSize="11"
                  Click="Help_Click"/>
          <Button Content="🤖 KI-Handoff" Classes="ghost" FontSize="11"
                  Click="AiHandoff_Click"/>
        </StackPanel>
      </Grid>

      <!-- Inhalt -->
      <ScrollViewer Grid.Row="1" Padding="28,16,28,8">
        <StackPanel Spacing="12">

          <!-- ── Status-Übersicht ─────────────────────────────────────────── -->
          <Border Background="#181828" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="10">
              <TextBlock Text="Pipeline-Status" FontSize="12" FontWeight="SemiBold"/>

              <!-- Release -->
              <Grid ColumnDefinitions="160,*,Auto">
                <TextBlock Grid.Column="0" Text="Release-Ordner"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding IsReleasePrepared}"
                           Text="✅ Vorbereitet"
                           FontSize="12" Foreground="#4ade80" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding !IsReleasePrepared}"
                           Text="⏳ Ausstehend"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
              </Grid>

              <!-- Hash-Vorbereitung -->
              <Grid ColumnDefinitions="160,*,Auto">
                <TextBlock Grid.Column="0" Text="Hash-Vorbereitung"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding IsSignaturePrepared}"
                           Text="✅ SHA256 berechnet"
                           FontSize="12" Foreground="#4ade80" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding !IsSignaturePrepared}"
                           Text="⏳ Ausstehend"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
              </Grid>

              <!-- ETW-Signatur -->
              <Grid ColumnDefinitions="160,*,Auto">
                <TextBlock Grid.Column="0" Text="ETW-Signatur (RSA)"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding IsEtwSigned}"
                           Text="✅ Kryptografisch signiert"
                           FontSize="12" Foreground="#4ade80" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding !IsEtwSigned}"
                           Text="🔑 Ausstehend"
                           FontSize="12" Foreground="#c9a227" VerticalAlignment="Center"/>
              </Grid>

              <!-- ETW-Verifikation -->
              <Grid ColumnDefinitions="160,*,Auto">
                <TextBlock Grid.Column="0" Text="Signatur-Prüfung"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding IsEtwSignatureVerified}"
                           Text="✅ Verifiziert"
                           FontSize="12" Foreground="#4ade80" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding !IsEtwSignatureVerified}"
                           Text="⏳ Ausstehend"
                           FontSize="12" Foreground="#4a5070" VerticalAlignment="Center"/>
              </Grid>

              <!-- Trust-Level -->
              <Grid ColumnDefinitions="160,*,Auto">
                <TextBlock Grid.Column="0" Text="Trust-Level"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding TrustLevel}"
                           FontSize="12"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                           VerticalAlignment="Center"/>
              </Grid>

              <!-- Marketplace-Freigabe -->
              <Grid ColumnDefinitions="160,*,Auto">
                <TextBlock Grid.Column="0" Text="Marketplace-Freigabe"
                           FontSize="12" Foreground="#8892a4" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding CanContinueToMarketplace}"
                           Text="🟢 Bereit"
                           FontSize="12" Foreground="#4ade80" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2"
                           IsVisible="{Binding !CanContinueToMarketplace}"
                           Text="⏳ Phase 5"
                           FontSize="12" Foreground="#4a5070" VerticalAlignment="Center"/>
              </Grid>

            </StackPanel>
          </Border>

          <!-- ── Phase 4.0: Hash-Vorbereitung ───────────────────────────── -->

          <!-- Wird vorbereitet... -->
          <StackPanel IsVisible="{Binding IsPreparingSignature}"
                      HorizontalAlignment="Center" Spacing="8" Margin="0,4,0,0">
            <TextBlock Text="🔐" FontSize="24" HorizontalAlignment="Center"/>
            <TextBlock Text="Hash-Berechnung läuft..."
                       FontSize="13" Foreground="#5865f2"
                       FontStyle="Italic" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- Hash-Ergebnis (nach Phase 4.0) -->
          <Border IsVisible="{Binding IsSignaturePrepared}"
                  Background="#0a140a" BorderBrush="#1a4a1a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="6">
              <TextBlock Text="📋 SHA256-Hashes" FontSize="12" FontWeight="SemiBold"
                         Foreground="#4ade80"/>
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding LastSignatureResult.PackageSha256,
                                  StringFormat='Paket:      {0}'}"
                           FontSize="10" Foreground="#8892a4"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                <TextBlock Text="{Binding LastSignatureResult.ReleaseInfoSha256,
                                  StringFormat='Release:    {0}'}"
                           FontSize="10" Foreground="#8892a4"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                <TextBlock Text="{Binding LastSignatureResult.InspectionReportSha256,
                                  StringFormat='Inspektion: {0}'}"
                           FontSize="10" Foreground="#8892a4"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
              </StackPanel>

              <!-- Hash-Prüfung läuft... -->
              <StackPanel IsVisible="{Binding IsVerifyingSignature}"
                          Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                <TextBlock Text="🔍" FontSize="11"/>
                <TextBlock Text="Hash-Integritätsprüfung läuft..."
                           FontSize="11" Foreground="#5865f2" FontStyle="Italic"/>
              </StackPanel>

              <!-- Hash-Prüfergebnis -->
              <Border IsVisible="{Binding LastVerificationResult,
                                  Converter={x:Static ObjectConverters.IsNotNull}}"
                      Background="#101020" CornerRadius="4" Padding="8,6">
                <StackPanel Spacing="4">
                  <TextBlock Text="{Binding LastVerificationResult.Summary}"
                             FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                  <ItemsControl ItemsSource="{Binding LastVerificationResult.Issues}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="services:ValidationIssue">
                        <TextBlock Margin="0,1" FontSize="10" Foreground="#e05252"
                                   Text="{Binding Title}" TextWrapping="Wrap"/>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </StackPanel>
              </Border>

              <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Classes="ghost" FontSize="11"
                        IsEnabled="{Binding CanVerifySignaturePreparation}"
                        Command="{Binding VerifySignaturePreparationCommand}">
                  🔍 Hash-Integrität prüfen
                </Button>
                <Button Classes="ghost" FontSize="11"
                        Command="{Binding OpenSignatureInfoCommand}">
                  signature-info.json öffnen
                </Button>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- ── Phase 4.1: ETW-Schlüssel ────────────────────────────────── -->
          <Border Background="#181828" BorderBrush="#2a2a4a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="8">
              <TextBlock Text="🔑 ETW-Entwickler-Schlüssel" FontSize="12" FontWeight="SemiBold"/>

              <!-- Schlüssel vorhanden -->
              <StackPanel IsVisible="{Binding EtwKeyExists}" Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="✅" FontSize="12" VerticalAlignment="Center"/>
                  <TextBlock Text="RSA-2048-Schlüsselpaar vorhanden"
                             FontSize="12" Foreground="#4ade80" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding CurrentEtwKeyInfo.EtwId,
                                  StringFormat='ETW-ID:      {0}'}"
                           FontSize="10" Foreground="#8892a4"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                <TextBlock Text="{Binding CurrentEtwKeyInfo.CreatedAtUtc,
                                  StringFormat='Erzeugt:     {0}'}"
                           FontSize="10" Foreground="#8892a4"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                <TextBlock Text="{Binding CurrentEtwKeyInfo.FingerprintShort,
                                  StringFormat='Fingerprint: {0}'}"
                           FontSize="10" Foreground="#8892a4"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                           ToolTip.Tip="{Binding CurrentEtwKeyInfo.Fingerprint}"/>
                <TextBlock Text="{Binding CurrentEtwKeyInfo.StorageMode,
                                  StringFormat='Speicher:    {0}'}"
                           FontSize="10" Foreground="#8892a4"
                           FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                <TextBlock Text="Privater Schlüssel: %APPDATA%/AAIA/Keys/ — NIEMALS in Git einchecken."
                           FontSize="10" Foreground="#c9a227" TextWrapping="Wrap"
                           Margin="0,2,0,0"/>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                  <Button Classes="ghost" FontSize="11"
                          Command="{Binding CopyPublicKeyCommand}">
                    📋 Public Key kopieren
                  </Button>
                  <Button Classes="ghost" FontSize="11"
                          Command="{Binding ExportPublicKeyCommand}">
                    💾 Public Key exportieren
                  </Button>
                </StackPanel>
              </StackPanel>

              <!-- Kein Schlüssel vorhanden -->
              <StackPanel IsVisible="{Binding !EtwKeyExists}" Spacing="6">
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="⚠️" FontSize="12" VerticalAlignment="Center"/>
                  <TextBlock Text="Noch kein ETW-Schlüssel vorhanden"
                             FontSize="12" Foreground="#c9a227" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock FontSize="11" Foreground="#8892a4" TextWrapping="Wrap">
                  Ein lokales RSA-2048-Schlüsselpaar ist notwendig, um das Paket
                  kryptografisch zu signieren. Der Schlüssel wird nur auf diesem
                  Rechner gespeichert und NIEMALS übertragen.
                </TextBlock>

                <!-- Schlüssel wird erzeugt... -->
                <StackPanel IsVisible="{Binding IsGeneratingEtwKey}"
                            Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="⏳" FontSize="12"/>
                  <TextBlock Text="RSA-2048-Schlüsselpaar wird erzeugt..."
                             FontSize="12" Foreground="#5865f2" FontStyle="Italic"/>
                </StackPanel>

                <Button Classes="primary" FontSize="12"
                        IsEnabled="{Binding CanGenerateEtwKey}"
                        Command="{Binding GenerateEtwKeyCommand}">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="🔑" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock Text="ETW-Schlüssel erzeugen" VerticalAlignment="Center"/>
                  </StackPanel>
                </Button>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- ── Phase 4.1: ETW-Signatur erstellen ──────────────────────── -->

          <!-- ETW-Signierung läuft... -->
          <StackPanel IsVisible="{Binding IsCreatingEtwSignature}"
                      HorizontalAlignment="Center" Spacing="8" Margin="0,4,0,0">
            <TextBlock Text="🔑" FontSize="24" HorizontalAlignment="Center"/>
            <TextBlock Text="ETW-Signatur wird erstellt..."
                       FontSize="13" Foreground="#5865f2"
                       FontStyle="Italic" HorizontalAlignment="Center"/>
          </StackPanel>

          <!-- ETW-Signatur-Ergebnis -->
          <Border IsVisible="{Binding IsEtwSigned}"
                  Background="#0a140a" BorderBrush="#1a5a1a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="6">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="✅" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="ETW-Signatur erstellt" FontSize="13" FontWeight="SemiBold"
                           Foreground="#4ade80" VerticalAlignment="Center"/>
              </StackPanel>
              <TextBlock Text="{Binding LastEtwSigningResult.EtwId,
                                StringFormat='Signiert von:  {0}'}"
                         FontSize="11" Foreground="#8892a4"/>
              <TextBlock Text="{Binding LastEtwSigningResult.SignedAtUtc,
                                StringFormat='Zeitstempel:   {0}'}"
                         FontSize="11" Foreground="#8892a4"/>
              <TextBlock Text="{Binding LastEtwSigningResult.Algorithm,
                                StringFormat='Algorithmus:   {0}'}"
                         FontSize="11" Foreground="#8892a4"/>
              <TextBlock Text="{Binding CurrentEtwKeyInfo.FingerprintShort,
                                StringFormat='Fingerprint:   {0}'}"
                         FontSize="11" Foreground="#8892a4"
                         FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                         ToolTip.Tip="{Binding CurrentEtwKeyInfo.Fingerprint}"/>

              <!-- ETW-Verifikation -->
              <StackPanel Spacing="6" Margin="0,4,0,0">

                <!-- ETW-Verifizierung läuft... -->
                <StackPanel IsVisible="{Binding IsVerifyingEtwSignature}"
                            Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="🔍" FontSize="11"/>
                  <TextBlock Text="ETW-Signaturprüfung läuft..."
                             FontSize="11" Foreground="#5865f2" FontStyle="Italic"/>
                </StackPanel>

                <!-- ETW-Prüfergebnis -->
                <Border IsVisible="{Binding LastEtwVerificationResult,
                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                        Background="#101020" CornerRadius="4" Padding="8,6">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding LastEtwVerificationResult.Summary}"
                               FontSize="11" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding LastEtwVerificationResult.SignerEtwId,
                                      StringFormat='ETW-ID:      {0}'}"
                               FontSize="10" Foreground="#8892a4"
                               FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"/>
                    <TextBlock Text="{Binding LastEtwVerificationResult.KeyFingerprint,
                                      StringFormat='Fingerprint: {0}'}"
                               FontSize="10" Foreground="#8892a4"
                               FontFamily="JetBrains Mono,Cascadia Code,Consolas,monospace"
                               TextWrapping="Wrap"/>
                    <ItemsControl ItemsSource="{Binding LastEtwVerificationResult.Issues}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="services:ValidationIssue">
                          <TextBlock Margin="0,1" FontSize="10"
                                     Foreground="#e05252"
                                     Text="{Binding Title}"
                                     TextWrapping="Wrap"/>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Button Classes="ghost" FontSize="11"
                        IsEnabled="{Binding CanVerifyEtwSignature}"
                        Command="{Binding VerifyEtwSignatureCommand}">
                  🔍 ETW-Signatur prüfen
                </Button>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- Marketplace-Hinweis -->
          <Border IsVisible="{Binding CanContinueToMarketplace}"
                  Background="#0a0a1e" BorderBrush="#2a2a6a"
                  BorderThickness="1" CornerRadius="8" Padding="14,12">
            <StackPanel Spacing="4">
              <TextBlock Text="🚀 Bereit für Marketplace-Upload (Phase 5)"
                         FontSize="12" FontWeight="SemiBold" Foreground="#5865f2"/>
              <TextBlock FontSize="11" Foreground="#8892a4" TextWrapping="Wrap">
                ETW-Signatur gültig. Das Paket kann jetzt zum AAIA-Marketplace hochgeladen werden.
                Upload-Funktion wird in Phase 5 implementiert.
              </TextBlock>
            </StackPanel>
          </Border>

        </StackPanel>
      </ScrollViewer>

      <!-- Button-Leiste -->
      <Border Grid.Row="2"
              BorderBrush="#2a2a4a" BorderThickness="0,1,0,0"
              Padding="28,10,28,20">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto">
          <Button Grid.Column="0"
                  Content="← Zurück" Classes="ghost"
                  Click="SignatureBack_Click"/>
          <Button Grid.Column="2"
                  Content="📁 Release-Ordner" Classes="ghost"
                  Margin="0,0,8,0"
                  IsEnabled="{Binding CanOpenReleaseFolder}"
                  Command="{Binding OpenReleaseFolderCommand}"/>
          <Button Grid.Column="3"
                  Content="Fertig" Classes="ghost"
                  Margin="0,0,8,0"
                  Click="Close_Click"/>
          <Button Grid.Column="4" Classes="ghost"
                  Margin="0,0,8,0"
                  IsEnabled="{Binding CanPrepareSignature}"
                  Command="{Binding PrepareSignatureCommand}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="🔐" FontSize="11" VerticalAlignment="Center"/>
              <TextBlock Text="Hash" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="5" Classes="primary"
                  Margin="0,0,8,0"
                  IsEnabled="{Binding CanCreateEtwSignature}"
                  Command="{Binding CreateEtwSignatureCommand}">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="🔑" FontSize="11" VerticalAlignment="Center"/>
              <TextBlock Text="ETW-Signatur" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="6" Classes="ghost"
                  Margin="0,0,8,0"
                  Click="AiHandoff_Click">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="🤖" FontSize="11" VerticalAlignment="Center"/>
              <TextBlock Text="KI-Handoff" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Grid.Column="7" Classes="ghost"
                  IsEnabled="{Binding CanContinueToMarketplace}"
                  Click="Marketplace_Click">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="🚀" FontSize="11" VerticalAlignment="Center"/>
              <TextBlock Text="Marketplace" FontSize="11" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </Grid>
      </Border>
    </Grid>

  </Grid>

</Window>
