<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AAIA.ModuleManager.ViewModels"
        x:Class="AAIA.ModuleManager.Views.LoginWindow"
        x:DataType="vm:LoginWindowViewModel"
        Title="AAIA Module Manager — Anmelden"
        Width="520" Height="660"
        MinWidth="420" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        Background="#1a1a2e">

  <Grid RowDefinitions="44,*,Auto">

    <!-- Titelzeile -->
    <Grid Grid.Row="0" Background="#12122a"
          IsHitTestVisible="True"
          PointerPressed="TitleBar_PointerPressed">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="10">
        <Image Source="avares://AAIA.ModuleManager/Assets/AAIA_Module_Manager.png"
               Width="20" Height="20" RenderOptions.BitmapInterpolationMode="HighQuality"/>
        <TextBlock Text="AAIA Module Manager" Foreground="#e0e0e0"
                   FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
      </StackPanel>

      <Button Grid.Column="1" Classes="wnd-btn close-btn" Content="✕"
              Click="Close_Click" Margin="0,0,8,0"/>
    </Grid>

    <!-- Hauptinhalt -->
    <ScrollViewer Grid.Row="1" Padding="32,24">
      <StackPanel Spacing="0">

        <!-- ── Login-Screen ── -->
        <StackPanel IsVisible="{Binding CurrentScreen, Converter={x:Static vm:ScreenConverter.IsLogin}}"
                    Spacing="20">
          <StackPanel Spacing="4">
            <TextBlock Text="Willkommen zurück" FontSize="22" FontWeight="Bold"
                       Foreground="#e0e0e0"/>
            <TextBlock Text="Melde dich mit deinem ETW-Account an."
                       Foreground="#8892a4" FontSize="13"/>
          </StackPanel>

          <StackPanel Spacing="12">
            <StackPanel Spacing="6">
              <TextBlock Text="E-Mail" Foreground="#8892a4" FontSize="12"/>
              <TextBox Text="{Binding LoginEmail}" Watermark="developer@example.com"
                       Classes="input-field"/>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="Passwort" Foreground="#8892a4" FontSize="12"/>
              <Grid>
                <TextBox Text="{Binding LoginPassword}"
                         PasswordChar="{Binding ShowLoginPassword, Converter={x:Static vm:PasswordVisibilityConverter.Instance}}"
                         Classes="input-field" Padding="10,8,44,8"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,6,0"
                        Command="{Binding ToggleLoginPasswordCommand}"
                        Content="{Binding ShowLoginPassword, Converter={x:Static vm:EyeIconConverter.Instance}}"
                        Classes="eye-btn"/>
              </Grid>
            </StackPanel>
            <StackPanel Spacing="6" IsVisible="{Binding LoginNeedsTotp}">
              <TextBlock Text="Authenticator-Code (6-stellig)" Foreground="#7c8cf8" FontSize="12"/>
              <TextBox Text="{Binding LoginTotp}" Watermark="000000"
                       MaxLength="6" Classes="input-field totp-field"/>
            </StackPanel>
          </StackPanel>

          <Button Content="Anmelden" Classes="primary-btn"
                  Command="{Binding LoginCommand}"
                  IsEnabled="{Binding !IsBusy}"
                  HorizontalAlignment="Stretch"/>

          <Separator Background="#2a2a4a" Height="1"/>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
            <TextBlock Text="Noch kein Account?" Foreground="#8892a4" FontSize="12"
                       VerticalAlignment="Center"/>
            <Button Content="Jetzt registrieren" Classes="link-btn"
                    Command="{Binding ShowRegisterCommand}"/>
          </StackPanel>
        </StackPanel>

        <!-- ── Register-Screen ── -->
        <StackPanel IsVisible="{Binding CurrentScreen, Converter={x:Static vm:ScreenConverter.IsRegister}}"
                    Spacing="20">
          <StackPanel Spacing="4">
            <TextBlock Text="ETW-Account anlegen" FontSize="22" FontWeight="Bold"
                       Foreground="#e0e0e0"/>
            <TextBlock Text="Du erhältst eine permanente Entwickler-ID (z.B. ETW-000042)."
                       Foreground="#8892a4" FontSize="13"/>
          </StackPanel>

          <StackPanel Spacing="12">
            <StackPanel Spacing="6">
              <TextBlock Text="Anzeigename" Foreground="#8892a4" FontSize="12"/>
              <TextBox Text="{Binding RegDisplayName}" Watermark="Max Mustermann"
                       Classes="input-field"/>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="E-Mail" Foreground="#8892a4" FontSize="12"/>
              <TextBox Text="{Binding RegEmail}" Watermark="developer@example.com"
                       Classes="input-field"/>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="Passwort (min. 8 Zeichen)" Foreground="#8892a4" FontSize="12"/>
              <Grid>
                <TextBox Text="{Binding RegPassword}"
                         PasswordChar="{Binding ShowRegPassword, Converter={x:Static vm:PasswordVisibilityConverter.Instance}}"
                         Classes="input-field" Padding="10,8,44,8"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,6,0"
                        Command="{Binding ToggleRegPasswordCommand}"
                        Content="{Binding ShowRegPassword, Converter={x:Static vm:EyeIconConverter.Instance}}"
                        Classes="eye-btn"/>
              </Grid>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="Passwort bestätigen" Foreground="#8892a4" FontSize="12"/>
              <Grid>
                <TextBox Text="{Binding RegPasswordConfirm}"
                         PasswordChar="{Binding ShowRegPasswordConfirm, Converter={x:Static vm:PasswordVisibilityConverter.Instance}}"
                         Classes="input-field" Padding="10,8,44,8"/>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Margin="0,0,6,0"
                        Command="{Binding ToggleRegPasswordConfirmCommand}"
                        Content="{Binding ShowRegPasswordConfirm, Converter={x:Static vm:EyeIconConverter.Instance}}"
                        Classes="eye-btn"/>
              </Grid>
            </StackPanel>
            <StackPanel Spacing="6">
              <TextBlock Text="GitHub (optional)" Foreground="#8892a4" FontSize="12"/>
              <TextBox Text="{Binding RegGitHub}" Watermark="github-username"
                       Classes="input-field"/>
            </StackPanel>
          </StackPanel>

          <Button Content="Account anlegen" Classes="primary-btn"
                  Command="{Binding RegisterCommand}"
                  IsEnabled="{Binding !IsBusy}"
                  HorizontalAlignment="Stretch"/>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
            <TextBlock Text="Bereits registriert?" Foreground="#8892a4" FontSize="12"
                       VerticalAlignment="Center"/>
            <Button Content="Anmelden" Classes="link-btn"
                    Command="{Binding ShowLoginCommand}"/>
          </StackPanel>
        </StackPanel>

        <!-- ── TOTP-Setup-Screen ── -->
        <StackPanel IsVisible="{Binding CurrentScreen, Converter={x:Static vm:ScreenConverter.IsTotpSetup}}"
                    Spacing="20">
          <StackPanel Spacing="4">
            <TextBlock Text="Authenticator einrichten" FontSize="22" FontWeight="Bold"
                       Foreground="#e0e0e0"/>
            <TextBlock TextWrapping="Wrap" Foreground="#8892a4" FontSize="13">
              <Run Text="Öffne deine Authenticator-App (AAIA oder Google Authenticator)"/>
              <Run Text=" und scanne den QR-Code oder gib den Key manuell ein."/>
            </TextBlock>
          </StackPanel>

          <!-- QR-Code-Bild (wird per Code-Behind gesetzt) -->
          <Border Background="#0d0d1e" CornerRadius="8" Padding="16"
                  HorizontalAlignment="Center">
            <StackPanel Spacing="12" HorizontalAlignment="Center">
              <Image x:Name="QrCodeImage" Width="200" Height="200"
                     HorizontalAlignment="Center"/>
              <TextBlock Text="QR-Code scannen" Foreground="#8892a4" FontSize="11"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Manueller Key -->
          <Border Background="#12122a" CornerRadius="6" Padding="12">
            <StackPanel Spacing="6">
              <TextBlock Text="Oder manuell eingeben:" Foreground="#8892a4" FontSize="11"/>
              <SelectableTextBlock Text="{Binding TotpSecret}"
                                   FontFamily="Consolas,Monospace"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#7c8cf8"
                                   HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- ETW-ID-Anzeige -->
          <Border Background="#0a1628" CornerRadius="6" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
              <TextBlock Text="Deine ETW-ID:" Foreground="#8892a4" FontSize="12"
                         VerticalAlignment="Center"/>
              <SelectableTextBlock Text="{Binding PendingEtwId}"
                                   Foreground="#7c8cf8" FontWeight="Bold" FontSize="14"
                                   VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Code-Eingabe -->
          <StackPanel Spacing="8">
            <TextBlock Text="6-stelligen Code eingeben:" Foreground="#8892a4" FontSize="12"/>
            <TextBox Text="{Binding TotpCode}" Watermark="000000"
                     MaxLength="6" Classes="input-field totp-field"
                     HorizontalAlignment="Center" Width="160"/>
          </StackPanel>

          <Button Content="Code bestätigen &amp; loslegen" Classes="primary-btn"
                  Command="{Binding VerifyTotpCommand}"
                  IsEnabled="{Binding !IsBusy}"
                  HorizontalAlignment="Stretch"/>

          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="6">
            <TextBlock Text="Etwas schiefgelaufen?" Foreground="#8892a4" FontSize="12"
                       VerticalAlignment="Center"/>
            <Button Content="Registrierung abbrechen"
                    Classes="link-btn danger-link"
                    Command="{Binding CancelRegistrationCommand}"
                    IsEnabled="{Binding !IsBusy}"/>
          </StackPanel>
        </StackPanel>

      </StackPanel>
    </ScrollViewer>

    <!-- Status-Zeile -->
    <Border Grid.Row="2" Background="#12122a" Padding="24,10" MinHeight="40">
      <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                 FontSize="12" VerticalAlignment="Center">
        <TextBlock.Styles>
          <Style Selector="TextBlock">
            <Setter Property="Foreground"
                    Value="{Binding IsError, Converter={x:Static vm:BoolToColorConverter.Instance}}"/>
          </Style>
        </TextBlock.Styles>
      </TextBlock>
    </Border>

  </Grid>

  <Window.Styles>
    <Style Selector="TextBox.input-field">
      <Setter Property="Background" Value="#12122a"/>
      <Setter Property="Foreground" Value="#e0e0e0"/>
      <Setter Property="BorderBrush" Value="#2a2a4a"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Height" Value="38"/>
    </Style>
    <Style Selector="TextBox.totp-field">
      <Setter Property="FontFamily" Value="Consolas,Monospace"/>
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="TextAlignment" Value="Center"/>
      <Setter Property="LetterSpacing" Value="4"/>
    </Style>
    <Style Selector="Button.primary-btn">
      <Setter Property="Background" Value="#5865f2"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="0,12"/>
      <Setter Property="FontSize" Value="14"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.primary-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#4752c4"/>
    </Style>
    <Style Selector="Button.link-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#7c8cf8"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.wnd-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#8892a4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="30"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style Selector="Button.close-btn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#c0392b"/>
      <Setter Property="TextElement.Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.eye-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#8892a4"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="34"/>
      <Setter Property="Padding" Value="4"/>
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style Selector="Button.danger-link">
      <Setter Property="Foreground" Value="#e74c3c"/>
    </Style>
    <Style Selector="Button.danger-link:pointerover /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="#c0392b"/>
    </Style>
    <Style Selector="Button.eye-btn:pointerover /template/ ContentPresenter">
      <Setter Property="TextElement.Foreground" Value="#e0e0e0"/>
    </Style>
  </Window.Styles>

</Window>
