<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AAIA.ModuleManager.ViewModels"
             x:Class="AAIA.ModuleManager.Views.Tabs.AdminMarketplaceTab"
             x:DataType="vm:AdminMarketplaceViewModel">

  <Grid RowDefinitions="Auto,*">

    <!-- ── Header ─────────────────────────────────────────────────────────── -->
    <StackPanel Grid.Row="0" Margin="20,18,20,12" Spacing="12">

      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Classes="h1" Text="🛡  Marketplace Console"/>
          <TextBlock Classes="muted" FontSize="12"
                     Text="Technische Betreiber-Übersicht — keine Finanzdaten"/>
        </StackPanel>
        <Button Grid.Column="1" Classes="ghost" Content="↻ Aktualisieren"
                Command="{Binding RefreshCommand}"
                IsEnabled="{Binding !IsLoading}"
                VerticalAlignment="Center"/>
      </Grid>

      <!-- Status -->
      <TextBlock Classes="muted" FontSize="12"
                 Text="{Binding StatusMessage}"
                 IsVisible="{Binding StatusMessage,
                     Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

      <!-- ── Kacheln-Zeile ───────────────────────────────────────────────── -->
      <WrapPanel Orientation="Horizontal">

        <!-- Extensions -->
        <Border Classes="stat-card">
          <StackPanel Spacing="4">
            <TextBlock Classes="stat-label" Text="Extensions"/>
            <TextBlock Classes="stat-value" Text="{Binding TotalExtensions}"/>
            <TextBlock Classes="stat-sub"
                       Text="{Binding PublishedExtensions,
                           StringFormat='{}{0} published'}"/>
          </StackPanel>
        </Border>

        <!-- Risk -->
        <Border Classes="stat-card risk-card">
          <StackPanel Spacing="4">
            <TextBlock Classes="stat-label" Text="Risk"/>
            <TextBlock Classes="stat-value" Foreground="#ef4444"
                       Text="{Binding HighRiskExtensions, StringFormat='🔴 {0}'}"/>
            <TextBlock Classes="stat-sub"
                       Text="{Binding MediumRiskExtensions,
                           StringFormat='🟡 {0} Medium'}"/>
          </StackPanel>
        </Border>

        <!-- Pending Reviews -->
        <Border Classes="stat-card">
          <StackPanel Spacing="4">
            <TextBlock Classes="stat-label" Text="Pending Review"/>
            <TextBlock Classes="stat-value"
                       Foreground="#f4a261"
                       Text="{Binding PendingReviewCount}"/>
            <TextBlock Classes="stat-sub"
                       Text="{Binding BlockedReleasesCount,
                           StringFormat='{}{0} gesperrt'}"/>
          </StackPanel>
        </Border>

        <!-- Lizenzen -->
        <Border Classes="stat-card">
          <StackPanel Spacing="4">
            <TextBlock Classes="stat-label" Text="Lizenzen"/>
            <TextBlock Classes="stat-value" Text="{Binding ActiveLicenses}"/>
            <TextBlock Classes="stat-sub"
                       Text="{Binding TotalLicenses,
                           StringFormat='{}{0} gesamt'}"/>
          </StackPanel>
        </Border>

        <!-- Webhooks 24h -->
        <Border Classes="stat-card">
          <StackPanel Spacing="4">
            <TextBlock Classes="stat-label" Text="Webhooks 24h"/>
            <TextBlock Classes="stat-value" Text="{Binding WebhookEventsLast24h}"/>
            <TextBlock Classes="stat-sub"
                       Text="{Binding TotalBuyerAccounts,
                           StringFormat='{}{0} Käuferkonten'}"/>
          </StackPanel>
        </Border>

        <!-- ETWs -->
        <Border Classes="stat-card">
          <StackPanel Spacing="4">
            <TextBlock Classes="stat-label" Text="ETW-Entwickler"/>
            <TextBlock Classes="stat-value" Text="{Binding TotalDevelopers}"/>
          </StackPanel>
        </Border>

      </WrapPanel>

    </StackPanel>

    <!-- ── Tab-Inhalt ────────────────────────────────────────────────────── -->
    <TabControl Grid.Row="1" Margin="12,0,12,12">

      <!-- Extensions -->
      <TabItem Header="📋  Extensions">
        <Grid RowDefinitions="Auto,*">

          <!-- Suche -->
          <TextBox Grid.Row="0" Margin="0,8,0,8"
                   Text="{Binding ExtensionSearch}"
                   Watermark="Extension suchen (Name, ID)…"
                   Padding="10,7" CornerRadius="6"
                   Background="#1e1e3a" Foreground="#e0e0e0"
                   BorderBrush="#2a2a4a" BorderThickness="1"/>

          <!-- Liste -->
          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Extensions}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:AdminExtensionRowVm">
                  <Border Margin="0,0,0,6" CornerRadius="6" Padding="12,10"
                          Background="#1a1a2e" BorderBrush="#2a2a4a" BorderThickness="1">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto,Auto">

                      <!-- Name + ID -->
                      <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="{Binding Name}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#e0e0e0"/>
                        <TextBlock Text="{Binding ExtensionId}"
                                   FontSize="10" FontFamily="Consolas,monospace"
                                   Foreground="#5a607a"/>
                        <TextBlock Text="{Binding PublisherName}"
                                   FontSize="10" Foreground="#8892a4"/>
                      </StackPanel>

                      <!-- Status-Badge -->
                      <Border Grid.Column="1" Margin="6,0" CornerRadius="4" Padding="6,3"
                              Background="#12122a" VerticalAlignment="Center">
                        <TextBlock Text="{Binding StatusBadge}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{Binding StatusColor}"/>
                      </Border>

                      <!-- Risk-Badge -->
                      <Border Grid.Column="2" Margin="6,0" CornerRadius="4" Padding="6,3"
                              Background="#12122a" VerticalAlignment="Center">
                        <TextBlock Text="{Binding RiskBadge}"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{Binding RiskColor}"/>
                      </Border>

                      <!-- Lizenzen -->
                      <StackPanel Grid.Column="3" Margin="6,0" VerticalAlignment="Center"
                                  HorizontalAlignment="Center">
                        <TextBlock Text="{Binding ActiveLicenses}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#06d6a0" HorizontalAlignment="Center"/>
                        <TextBlock Text="Lizenzen"
                                   FontSize="9" Foreground="#5a607a"
                                   HorizontalAlignment="Center"/>
                      </StackPanel>

                      <!-- Sales -->
                      <StackPanel Grid.Column="4" Margin="6,0" VerticalAlignment="Center"
                                  HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SalesCount}"
                                   FontSize="14" FontWeight="Bold"
                                   Foreground="#5865f2" HorizontalAlignment="Center"/>
                        <TextBlock Text="Verkäufe"
                                   FontSize="9" Foreground="#5a607a"
                                   HorizontalAlignment="Center"/>
                      </StackPanel>

                      <!-- MoR + Version -->
                      <StackPanel Grid.Column="5" Margin="6,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MorProvider, TargetNullValue='kein MoR'}"
                                   FontSize="10" Foreground="#8892a4"/>
                        <TextBlock Text="{Binding LatestVersion, StringFormat='v{0}', TargetNullValue='—'}"
                                   FontSize="10" Foreground="#5a607a"/>
                      </StackPanel>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </TabItem>

      <!-- Pending Reviews / Sicherheitsprüfung -->
      <TabItem Header="🔍  Pending Review">
        <Grid RowDefinitions="Auto,*">

          <TextBlock Grid.Row="0" Margin="0,8,0,8" FontSize="12" Foreground="#8892a4"
                     Text="Releases mit TrustLevel=MarketplaceVerified, die noch nicht veröffentlicht sind. Review und ggf. Blockierung."/>

          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding PendingReviews}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:PendingReviewRowVm">
                  <Border Margin="0,0,0,8" CornerRadius="6" Padding="14,12"
                          Background="#1a1a2e" BorderBrush="#2a2a4a" BorderThickness="1">
                    <Grid RowDefinitions="Auto,Auto,Auto">

                      <!-- Zeile 1: Extension + Version -->
                      <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto">
                        <StackPanel Grid.Column="0" Spacing="3">
                          <TextBlock Text="{Binding ExtensionName}"
                                     FontSize="14" FontWeight="SemiBold"
                                     Foreground="#e0e0e0"/>
                          <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding ExtensionId}"
                                       FontSize="10" FontFamily="Consolas,monospace"
                                       Foreground="#5a607a"/>
                            <TextBlock Text="{Binding Version, StringFormat='v{0}'}"
                                       FontSize="10" Foreground="#5865f2"/>
                            <TextBlock Text="{Binding PublisherName}"
                                       FontSize="10" Foreground="#8892a4"/>
                          </StackPanel>
                        </StackPanel>

                        <!-- Risk-Badge -->
                        <Border Grid.Column="1" Margin="8,0" CornerRadius="4" Padding="8,4"
                                Background="#12122a" VerticalAlignment="Center">
                          <TextBlock Text="{Binding RiskLevel, TargetNullValue='Risk: ?'}"
                                     FontSize="11" FontWeight="SemiBold"
                                     Foreground="{Binding RiskColor}"/>
                        </Border>

                        <!-- Tage wartend -->
                        <Border Grid.Column="2" CornerRadius="4" Padding="8,4"
                                VerticalAlignment="Center"
                                Background="#1a100a" BorderBrush="#f4a261" BorderThickness="1">
                          <TextBlock Text="{Binding DaysPending, StringFormat='{}{0}d wartend'}"
                                     FontSize="10" Foreground="#f4a261"/>
                        </Border>
                      </Grid>

                      <!-- Zeile 2: Grund eingeben -->
                      <Grid Grid.Row="1" Margin="0,10,0,0" ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Margin="0,0,8,0"
                                 Text="{Binding BlockReason}"
                                 Watermark="Blockierungsgrund (optional)…"
                                 Padding="8,6" CornerRadius="4"
                                 Background="#12122a" Foreground="#e0e0e0"
                                 BorderBrush="#2a2a4a" BorderThickness="1"
                                 FontSize="11"/>
                        <Button Grid.Column="1" Content="🚫  Blockieren"
                                Classes="danger"
                                FontSize="11" Padding="10,6"
                                Command="{Binding BlockCommand}"/>
                      </Grid>

                      <!-- Zeile 3: Trust-Level -->
                      <TextBlock Grid.Row="2" Margin="0,6,0,0"
                                 Text="{Binding TrustLevel, StringFormat='Trust: {0}', TargetNullValue='Trust: —'}"
                                 FontSize="10" Foreground="#5a607a"/>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

        </Grid>
      </TabItem>


      <!-- ── MoR Account Status Tab (Phase 5.11) ─────────────────────────── -->
      <TabItem Header="🔗  MoR Status">
        <Grid RowDefinitions="Auto,*">

          <!-- MoR Zusammenfassung -->
          <Border Grid.Row="0" Margin="0,0,0,8" CornerRadius="6" Padding="14,10"
                  Background="#0d1a0d" BorderBrush="#1a4d1a" BorderThickness="1">
            <Grid ColumnDefinitions="*,*,*,*">
              <StackPanel Grid.Column="0" Spacing="2">
                <TextBlock Text="ETW-Konten gesamt" FontSize="9" Foreground="#5a607a"/>
                <TextBlock Text="{Binding MorTotalEtws}" FontSize="22" FontWeight="Bold"
                           Foreground="#e0e0e0"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Spacing="2">
                <TextBlock Text="Mit MoR-Mapping" FontSize="9" Foreground="#5a607a"/>
                <TextBlock Text="{Binding MorEtwsWithMapping}" FontSize="22" FontWeight="Bold"
                           Foreground="#4caf50"/>
              </StackPanel>
              <StackPanel Grid.Column="2" Spacing="2">
                <TextBlock Text="Mit Checkout" FontSize="9" Foreground="#5a607a"/>
                <TextBlock Text="{Binding MorEtwsWithCheckout}" FontSize="22" FontWeight="Bold"
                           Foreground="#4f8ef7"/>
              </StackPanel>
              <StackPanel Grid.Column="3" Spacing="2">
                <TextBlock Text="Probleme" FontSize="9" Foreground="#5a607a"/>
                <TextBlock Text="{Binding MorEtwsWithIssues}" FontSize="22" FontWeight="Bold"
                           Foreground="#e57373"/>
              </StackPanel>
            </Grid>
          </Border>

          <!-- ETW-Liste -->
          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding MorAccountItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,4" CornerRadius="5" Padding="10,8"
                          Background="#12151a" BorderBrush="#2a2d35" BorderThickness="1">
                    <Grid ColumnDefinitions="24,180,*,100,100,130">

                      <!-- Status-Ampel -->
                      <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="14"
                                 Text="{Binding StatusEmoji}"/>

                      <!-- ETW-ID + Name -->
                      <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontSize="12" FontWeight="SemiBold" Foreground="#c9d1d9"/>
                        <TextBlock Text="{Binding EtwId}"
                                   FontSize="10" Foreground="#5a607a"/>
                      </StackPanel>

                      <!-- Provider -->
                      <StackPanel Grid.Column="2" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Provider, TargetNullValue='—'}"
                                   FontSize="11" Foreground="#8892a4"/>
                        <TextBlock FontSize="9" Foreground="#5a607a"
                                   Text="{Binding ActiveMappings,
                                     StringFormat='{}{0} aktives Mapping(s)'}"/>
                      </StackPanel>

                      <!-- Extensions -->
                      <StackPanel Grid.Column="3" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding TotalExtensions}" FontSize="16"
                                   FontWeight="Bold" Foreground="#e0e0e0"/>
                        <TextBlock Text="Extensions" FontSize="9" Foreground="#5a607a"/>
                      </StackPanel>

                      <!-- Checkout -->
                      <StackPanel Grid.Column="4" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ExtensionsWithCheckout}" FontSize="16"
                                   FontWeight="Bold" Foreground="#4f8ef7"/>
                        <TextBlock Text="mit Checkout" FontSize="9" Foreground="#5a607a"/>
                      </StackPanel>

                      <!-- Letzter Webhook -->
                      <StackPanel Grid.Column="5" Spacing="1" VerticalAlignment="Center">
                        <TextBlock FontSize="10" Foreground="#8892a4"
                                   Text="{Binding LastWebhookLabel}"/>
                        <TextBlock Text="{Binding WebhookHealthy,
                                     Converter={StaticResource BoolToHealthLabel}}"
                                   FontSize="9" Foreground="#5a607a"/>
                      </StackPanel>

                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

        </Grid>
      </TabItem>

    </TabControl>

  </Grid>

  <UserControl.Styles>
    <Style Selector="Border.stat-card">
      <Setter Property="Background"    Value="#1a1a2e"/>
      <Setter Property="BorderBrush"   Value="#2a2a4a"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius"  Value="8"/>
      <Setter Property="Padding"       Value="16,12"/>
      <Setter Property="Margin"        Value="0,0,10,8"/>
      <Setter Property="Width"         Value="140"/>
    </Style>
    <Style Selector="Border.risk-card">
      <Setter Property="BorderBrush" Value="#4a2020"/>
    </Style>
    <Style Selector="TextBlock.stat-label">
      <Setter Property="FontSize"    Value="10"/>
      <Setter Property="Foreground"  Value="#8892a4"/>
      <Setter Property="FontWeight"  Value="SemiBold"/>
    </Style>
    <Style Selector="TextBlock.stat-value">
      <Setter Property="FontSize"    Value="26"/>
      <Setter Property="FontWeight"  Value="Bold"/>
      <Setter Property="Foreground"  Value="#e0e0e0"/>
    </Style>
    <Style Selector="TextBlock.stat-sub">
      <Setter Property="FontSize"    Value="10"/>
      <Setter Property="Foreground"  Value="#5a607a"/>
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Background"  Value="#4a1010"/>
      <Setter Property="Foreground"  Value="#ef4444"/>
      <Setter Property="BorderBrush" Value="#6a1010"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Cursor"      Value="Hand"/>
    </Style>
    <Style Selector="Button.danger:pointerover /template/ ContentPresenter">
      <Setter Property="Background"  Value="#6a1515"/>
    </Style>
  </UserControl.Styles>

</UserControl>
