<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="AAIA.ModuleManager.Views.SettingsWindow"
        Title="{DynamicResource Str_Settings_Title}"
        Width="500" Height="510"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#1a1a2e"
        Foreground="#e0e0e0"
        FontFamily="Inter,Segoe UI,sans-serif">

  <StackPanel Margin="28,24" Spacing="18">
    <TextBlock Text="{DynamicResource Str_Settings_Title}" FontSize="16" FontWeight="Bold"/>

    <!-- Verbindung -->
    <Border Background="#202042"
            BorderBrush="#2a2a4a"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
      <StackPanel Spacing="10">
        <TextBlock Text="Verbindungen" FontSize="13" FontWeight="SemiBold"/>

        <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto">
          <TextBlock Grid.Row="0" Grid.Column="0" Text="AAIA Konto" Foreground="#8892a4" FontSize="12"/>
          <TextBlock x:Name="MarketplaceStatusText"
                     Grid.Row="0" Grid.Column="1"
                     Text="wird geprüft..."
                     TextWrapping="Wrap"/>

          <TextBlock Grid.Row="1" Grid.Column="0" Text="GitHub" Foreground="#8892a4" FontSize="12" Margin="0,6,0,0"/>
          <TextBlock x:Name="GithubStatusText"
                     Grid.Row="1" Grid.Column="1"
                     Text="wird geprüft..."
                     TextWrapping="Wrap"
                     Margin="0,6,0,0"/>

          <TextBlock Grid.Row="2" Grid.Column="0" Text="AAIAS" Foreground="#8892a4" FontSize="12" Margin="0,6,0,0"/>
          <TextBlock x:Name="AaiasStatusText"
                     Grid.Row="2" Grid.Column="1"
                     Text="wird geprüft..."
                     TextWrapping="Wrap"
                     Margin="0,6,0,0"/>
        </Grid>
      </StackPanel>
    </Border>

    <!-- Sprache -->
    <StackPanel Spacing="6">
      <TextBlock Text="{DynamicResource Str_Settings_Language}" Foreground="#8892a4" FontSize="12"/>
      <StackPanel Orientation="Horizontal" Spacing="16">
        <RadioButton x:Name="RadioDe"
                     Content="{DynamicResource Str_Settings_De}"
                     IsChecked="True"
                     Foreground="#e0e0e0"/>
        <RadioButton x:Name="RadioEn"
                     Content="{DynamicResource Str_Settings_En}"
                     Foreground="#e0e0e0"/>
      </StackPanel>
    </StackPanel>

    <!-- Marketplace API URL -->
    <StackPanel Spacing="6">
      <TextBlock Text="Marketplace API URL" Foreground="#8892a4" FontSize="12"/>
      <TextBox x:Name="ApiUrlBox"
               Watermark="https://aaiagent.de/index.php?rest_route=/aaia/v1"
               Background="#12122a" Foreground="#e0e0e0"
               BorderBrush="#2a2a4a" BorderThickness="1"
               CornerRadius="6" Padding="10,7" FontSize="12"/>
      <TextBlock Foreground="#5865f2" FontSize="11"
                 Text="Live: https://aaiagent.de/index.php?rest_route=/aaia/v1"/>
    </StackPanel>

    <!-- Marketplace Backend API URL (ASP.NET Core) -->
    <StackPanel Spacing="6">
      <TextBlock Text="Marketplace Backend API URL" Foreground="#8892a4" FontSize="12"/>
      <TextBox x:Name="BackendApiUrlBox"
               Watermark="https://api.marketplace.aaia.app"
               Background="#12122a" Foreground="#e0e0e0"
               BorderBrush="#2a2a4a" BorderThickness="1"
               CornerRadius="6" Padding="10,7" FontSize="12"/>
      <TextBlock Foreground="#5a607a" FontSize="11"
                 Text="Wird für Lizenzaktivierung (JWT) verwendet — getrennt vom WooCommerce-Endpunkt."/>
    </StackPanel>

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Classes="ghost"
              Content="{DynamicResource Str_Cancel}"
              Click="Cancel_Click"/>
      <Button Classes="primary"
              Content="{DynamicResource Str_Save}"
              Click="Save_Click"/>
    </StackPanel>
  </StackPanel>

</Window>
